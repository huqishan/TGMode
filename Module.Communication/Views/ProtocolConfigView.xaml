<UserControl x:Class="Module.Communication.Views.ProtocolConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             xmlns:vm="clr-namespace:Module.Communication.ViewModels"
             xmlns:luaScript="clr-namespace:ControlLibrary.Controls.LuaScripEditor.Control;assembly=ControlLibrary"
             xmlns:luaCompiler="clr-namespace:ControlLibrary.ControlViews.LuaScrip;assembly=ControlLibrary"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.DataContext>
        <vm:ProtocolConfigViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="ProtocolOptionItemTemplate">
            <TextBlock Foreground="{DynamicResource AppContentTextBrush}" Text="{Binding DisplayName}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="协议配置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="一个协议对应一种设备；协议下维护多条指令，每条指令有独立模板、占位符、校验和返回解析规则。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <searchBox:SearchBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     PlaceholderText="搜索协议配置..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,16">
                    <Button Content="新建"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding NewProfileCommand}" />
                    <Button Content="复制"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding DuplicateProfileCommand}" />
                    <Button Content="删除"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding DeleteProfileCommand}" />
                    <Button Content="保存"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding SaveProfilesCommand}" />
                </UniformGrid>

                <ListBox Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding ProfilesView}"
                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MinHeight="130"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前协议" />
                            <Border HorizontalAlignment="Right"
Margin="16,0,0,0"
Padding="12,6"
VerticalAlignment="Top"
Background="{DynamicResource TabCardBackgroundBrush}"
BorderBrush="{DynamicResource TabItemBorderBrush}"
BorderThickness="1"
CornerRadius="999">
                                <TextBlock FontWeight="SemiBold"
       Foreground="{Binding PageStatusBrush}"
       Text="{Binding PageStatusText}" />
                            </Border>
                        </DockPanel>
                        
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="协议名称" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="{Binding SelectedProfile.Summary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  x:Name="ProtocolContentRegion"
                  ClipToBounds="True">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="设备指令" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="新建指令"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{Binding NewCommandCommand}" />
                                <Button Content="复制指令"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DuplicateCommandCommand}" />
                                <Button Content="删除指令"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DeleteCommandCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,10"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="&#x70b9;&#x51fb;&#x67d0;&#x6761;&#x8bbe;&#x5907;&#x6307;&#x4ee4;&#x540e;&#xff0c;&#x4f1a;&#x4ece;&#x4e0b;&#x4fa7;&#x6ed1;&#x51fa;&#x5f39;&#x7a97;&#xff0c;&#x663e;&#x793a;&#x57fa;&#x7840;&#x8bbe;&#x7f6e;&#x3001;&#x6267;&#x884c;&#x884c;&#x4e3a;&#x3001;&#x534f;&#x8bae;&#x6a21;&#x677f;&#x4e0e;&#x5360;&#x4f4d;&#x7b26;&#x3001;&#x8fd4;&#x56de;&#x793a;&#x4f8b;&#x4e0e; Lua &#x89e3;&#x6790;&#x811a;&#x672c;&#x3002;"
                                   TextWrapping="Wrap" />

                        <ListBox Grid.Row="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemsSource="{Binding SelectedProfile.Commands}"
                                 SelectedItem="{Binding SelectedProfile.SelectedCommand, Mode=TwoWay}"
                                 PreviewMouseLeftButtonUp="CommandListBox_PreviewMouseLeftButtonUp"
                                 ItemContainerStyle="{StaticResource ListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Grid x:Name="CommandDrawerHost"
                      Panel.ZIndex="10"
                      Opacity="0"
                      IsHitTestVisible="False">
                    <Border Background="#3A000000"
                            MouseLeftButtonDown="CommandDrawerBackdrop_MouseLeftButtonDown" />

                    <Border x:Name="CommandDrawerSheet"
                            Margin="0,56,0,0"
                            MaxHeight="{Binding ActualHeight, ElementName=ProtocolContentRegion}"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource DrawerBorderStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CommandDrawerTranslateTransform" Y="56" />
                        </Border.RenderTransform>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="指令编辑" />
                                <Button DockPanel.Dock="Right"
                                        Content="关闭"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding CloseCommandDrawerCommand}" />
                            </DockPanel>

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,14,0,0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基础设置" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="指令名称" />
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding SelectedProfile.CommandName, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="发送格式" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding PayloadFormats}"
                                                          SelectedValue="{Binding SelectedProfile.RequestFormat, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="返回格式" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding PayloadFormats}"
                                                          SelectedValue="{Binding SelectedProfile.ResponseFormat, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="执行行为" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="强制等待拼接时长(ms)" />
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding SelectedProfile.ReplyAggregationMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding ReplyWaitHelpText}"
                                                           TextWrapping="Wrap" />

                                                <CheckBox Margin="0,14,0,0"
                                                          Foreground="{DynamicResource AppContentTextBrush}"
                                                          Content="等待数据返回"
                                                          IsChecked="{Binding SelectedProfile.WaitForResponse, Mode=TwoWay}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding WaitForResponseHelpText}"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="CRC校验" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding CrcModes}"
                                                          SelectedValue="{Binding SelectedProfile.CrcMode, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding CrcHelpText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="16" />
                                                <RowDefinition Height="180" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       Text="协议模板与占位符" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,8,0,0"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding PlaceholderHelpText}"
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="协议内容模板" />
                                                <TextBox Grid.Row="1"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding SelectedProfile.ContentTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="占位符值" />
                                                <DataGrid Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                                          ItemsSource="{Binding SelectedProfile.PlaceholderValues}"
                                                          Style="{StaticResource ColumnsDataGridStyle}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Width="1.1*"
                                                                            Header="占位符"
                                                                            IsReadOnly="True"
                                                                            ElementStyle="{StaticResource CellTextBlockStyle}"
                                                                            Binding="{Binding Name}" />
                                                        <DataGridTextColumn Width="1.2*"
                                                                            Header="值"
                                                                            ElementStyle="{StaticResource CellTextBlockStyle}"
                                                                            EditingElementStyle="{StaticResource CellTextBoxStyle}"
                                                                            Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataGrid.Columns>
                                                </DataGrid>

                                                <Button Grid.Column="1"
                                                        Grid.Row="1" Grid.RowSpan="2"
                                                        Content=">>" FontSize="20"
                                                        Style="{StaticResource ConvertButtonStyle}"
                                                        Command="{Binding GenerateCommandCommand}" />

                                                <TextBlock Grid.Column="2"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Text="实际指令" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         x:Name="command"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         IsReadOnly="True"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding GeneratedCommandText, Mode=OneWay}" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Style="{StaticResource CardBorderStyle}"
                                            Visibility="{Binding SelectedProfile.WaitForResponse, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="16" />
                                                <RowDefinition Height="180" />
                                            </Grid.RowDefinitions>
                                            

                                            <TextBlock Grid.Row="0"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       Text="&#x8fd4;&#x56de;&#x793a;&#x4f8b;&#x4e0e; Lua &#x89e3;&#x6790;&#x811a;&#x672c;" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="3"
                                                       Margin="0,8,0,0"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding ParseRuleHelpText}"
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="示例返回数据" />
                                                <TextBox Grid.Row="1"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding SelectedProfile.SampleResponseText, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Lua &#x89e3;&#x6790;&#x811a;&#x672c;" />
                                                <luaScript:LuaScriptEditor x:Name="ParseRulesLuaEditor"
                                                                           Grid.Row="1"
                                                                           PreviewMouseDoubleClick="ParseRulesLuaEditor_PreviewMouseDoubleClick"
                                                                           ScriptText="{Binding SelectedProfile.ParseRulesText, UpdateSourceTrigger=PropertyChanged}" />
                                                <!--<TextBox Grid.Row="1"
      Style="{StaticResource InputTextBoxStyle}"
      AcceptsReturn="True"
      FontFamily="Consolas"
      VerticalAlignment="Stretch"
      VerticalScrollBarVisibility="Auto"
      Text="{Binding SelectedProfile.ParseRulesText, UpdateSourceTrigger=PropertyChanged}" />-->

                                                <Button Grid.Row="1"
        Grid.Column="1" Grid.RowSpan="2"
        Content=">>" FontSize="20"
        Style="{StaticResource ConvertButtonStyle}"
        Command="{Binding ParseResultCommand}" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="解析结果" Grid.Row="0" Grid.Column="2"/>
                                                <TextBox Grid.Row="1" Grid.Column="2"
x:Name="result"
Style="{StaticResource InputTextBoxStyle}"
AcceptsReturn="True"
FontFamily="Consolas"
IsReadOnly="True"
VerticalAlignment="Stretch"
VerticalScrollBarVisibility="Auto"
Text="{Binding ParsedResultText, Mode=OneWay}" />
                                            </Grid>
                                            
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="ParseRuleEditorHost"
              Grid.ColumnSpan="3"
              Panel.ZIndex="80"
              Visibility="Collapsed">
            <Border Background="#59000000"
                    MouseLeftButtonDown="ParseRuleEditorBackdrop_MouseLeftButtonDown" />

            <Border Width="980"
                    MaxWidth="1180"
                    MaxHeight="760"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="Lua &#x89e3;&#x6790;&#x811a;&#x672c;" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="data &#x8868;&#x793a;&#x5f53;&#x524d;&#x8fd4;&#x56de;&#x6570;&#x636e;&#xff0c;&#x811a;&#x672c;&#x53ea;&#x9700; return &#x4efb;&#x610f;&#x503c;&#x3002;" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding PageStatusBrush}"
                                   Text="{Binding PageStatusText}" />
                    </DockPanel>

                    <luaCompiler:LuaScriptCompilerView x:Name="ParseRuleCompilerView"
                                                       Grid.Row="1"
                                                       Margin="0,14,0,0" />

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="&#x53d6;&#x6d88;"
                                Click="ParseRuleEditorCancelButton_Click"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="&#x4fdd;&#x5b58;"
                                Click="ParseRuleEditorSaveButton_Click"
                                Style="{StaticResource PrimaryActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
