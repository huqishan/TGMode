<UserControl x:Class="Module.User.Views.PermissionConfigurationView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Module.User.ViewModels"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.DataContext>
        <vm:PermissionConfigurationViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="PermissionDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PermissionDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PermissionDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PermissionCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>

        <Style x:Key="PermissionExpandButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PermissionCellTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="True">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="角色" />
                        <Border Padding="10,5" Margin="16,0,0,0"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding RoleCountText}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="选择角色后，在右侧配置该角色可看到、可点击的界面、弹窗和按钮。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,16">
                    <Button Content="新建"
                            Command="{Binding NewRoleCommand}"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
                            Command="{Binding DuplicateRoleCommand}"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteRoleCommand}"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <ListBox Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding PermissionRoles}"
                         SelectedItem="{Binding SelectedRole, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MinHeight="130"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" MinWidth="360">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前角色" />
                            <StackPanel Orientation="Horizontal">
                                <StackPanel MinWidth="360">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="角色名称" />
                                    <TextBox Style="{StaticResource InputTextBoxStyle}"
IsEnabled="{Binding CanEditPermissions}"
Text="{Binding SelectedRole.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                </StackPanel>
                                <StackPanel MinWidth="150" Margin="16,0,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="权限等级" />
                                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
 ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
 IsEnabled="{Binding CanEditPermissions}"
 ItemsSource="{Binding PermissionLevelOptions}"
 DisplayMemberPath="DisplayName"
 SelectedValuePath="Level"
 SelectedValue="{Binding SelectedRole.Level, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                            
                            
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource AppMutedTextBlockStyle}"
                                       Text="{Binding SummaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Padding="12,6"
                                VerticalAlignment="Top"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}"
                                       Text="{Binding StatusText}" />
                        </Border>
                    </DockPanel>

                    <WrapPanel Grid.Row="2"
                               HorizontalAlignment="Right">
                        <Button Content="重新扫描"
                                Command="{Binding ReloadCommand}"
                                IsEnabled="{Binding CanEditPermissions}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="全部显示"
                                Command="{Binding ShowAllCommand}"
                                IsEnabled="{Binding CanEditPermissions}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="全部选中"
                                Command="{Binding SelectAllCommand}"
                                IsEnabled="{Binding CanEditPermissions}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="取消选中"
                                Command="{Binding ClearSelectionCommand}"
                                IsEnabled="{Binding CanEditPermissions}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="全部展开"
                                Command="{Binding ExpandAllCommand}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="全部折叠"
                                Command="{Binding CollapseAllCommand}"
                                Style="{StaticResource ActionButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <DataGrid ItemsSource="{Binding PermissionRows}"
                              IsEnabled="{Binding CanEditPermissions}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              AlternationCount="2"
                              RowHeight="42"
                              Background="{DynamicResource TabCardBackgroundBrush}"
                              Foreground="{DynamicResource AppContentTextBrush}"
                              ColumnHeaderStyle="{StaticResource PermissionDataGridHeaderStyle}"
                              RowStyle="{StaticResource PermissionDataGridRowStyle}"
                              CellStyle="{StaticResource PermissionDataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="界面 / 弹窗 / 按钮"
                                                    Width="280"
                                                    MinWidth="220"
                                                    MaxWidth="360">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="{Binding IndentWidth}" />
                                            <Button Grid.Column="1"
                                                    Content="{Binding ExpandGlyph}"
                                                    Command="{Binding DataContext.ToggleNodeCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding HasChildren}"
                                                    Style="{StaticResource PermissionExpandButtonStyle}" />
                                            <Border Grid.Column="2"
                                                    MinWidth="46"
                                                    Margin="0,0,10,0"
                                                    Padding="8,3"
                                                    Background="{DynamicResource TabCardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding KindDisplayName}" />
                                            </Border>
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="标识"
                                                Width="150"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource PermissionCellTextBlockStyle}"
                                                Binding="{Binding ElementIdentifier}" />

                            <DataGridCheckBoxColumn Header="显示"
                                                    Width="72"
                                                    ElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                    EditingElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                    Binding="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <DataGridCheckBoxColumn Header="使能"
                                                    Width="72"
                                                    ElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                    EditingElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                    Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <DataGridTextColumn x:Name="SourceColumn"
                                                Header="来源"
                                                Width="1.2*"
                                                MinWidth="300"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource PermissionCellTextBlockStyle}"
                                                Binding="{Binding SourcePath}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
