<UserControl x:Class="Module.User.Views.AccountManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Module.User.ViewModels"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1500">
    <UserControl.DataContext>
        <vm:AccountManagementViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="DataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="DataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource NavSelectedItemBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource NavSelectedBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource NavSelectedItemBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource NavSelectedBorderBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CellTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type DataGridCell}}}" />
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppContentTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="账号管理" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{Binding AccountSummaryText}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="新增"
                            Command="{Binding NewAccountCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveAccountCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteAccountCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Border Padding="12,6"
                            VerticalAlignment="Top"
                            Background="{DynamicResource TabCardBackgroundBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{Binding PageStatusBrush}"
                                   Text="{Binding PageStatusText}" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="680" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="账号列表" />
                        <Border DockPanel.Dock="Right"
                                Padding="10,5"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold" Text="{Binding AccountCountText}" />
                        </Border>
                    </DockPanel>

                    <DataGrid x:Name="AccountsDataGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource TabCardBackgroundBrush}"
                              Foreground="{DynamicResource AppContentTextBrush}"
                              RowBackground="{DynamicResource TabCardBackgroundBrush}"
                              AlternatingRowBackground="{DynamicResource TabItemBackgroundBrush}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowHeight="44">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="账号"
                                                Width="1.1*"
                                                ElementStyle="{StaticResource CellTextBlockStyle}"
                                                Binding="{Binding Account}" />
                            <DataGridTextColumn Header="姓名"
                                                Width="1.1*"
                                                ElementStyle="{StaticResource CellTextBlockStyle}"
                                                Binding="{Binding Name}" />
                            <DataGridTextColumn Header="角色"
                                                Width="170"
                                                ElementStyle="{StaticResource CellTextBlockStyle}"
                                                Binding="{Binding PermissionDisplayName}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding EditorTitle}" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="账号" />
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding EditingAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="姓名" />
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="角色" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              ItemsSource="{Binding PermissionOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding EditingPermissionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="密码" />
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordInput_PasswordChanged"
                                 Style="{StaticResource InputPasswordBoxStyle}" />

                    <Border Height="1"
                            Margin="0,20,0,6"
                            Background="{DynamicResource TabItemBorderBrush}" />

                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="{Binding EditorSummaryText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
