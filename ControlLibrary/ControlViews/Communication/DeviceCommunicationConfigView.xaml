<UserControl x:Class="ControlLibrary.ControlViews.Communication.DeviceCommunicationConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:convert="clr-namespace:ControlLibrary.Converts"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <convert:ComparisonToVisibilityConvert x:Key="ComparisonToVisibilityConvert"/>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,14,0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextElement.Foreground" Value="Black" />
        </Style>

        <Style x:Key="InputComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <DataTemplate x:Key="CommunicationTypeItemTemplate">
            <TextBlock Foreground="Black" Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="SelectionOptionItemTemplate">
            <TextBlock Foreground="Black" Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="PortNameItemTemplate">
            <TextBlock Foreground="Black" Text="{Binding}" />
        </DataTemplate>

        <Style x:Key="ConnectedClientComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ConnectedClientComboBoxItemStyle"
               TargetType="ComboBoxItem"
               BasedOn="{StaticResource InputComboBoxItemStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <DataTemplate x:Key="ConnectedClientItemTemplate">
            <TextBlock Foreground="{DynamicResource AppContentTextBrush}"
                       FontWeight="SemiBold"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
        </Style>

        <Style x:Key="ConfigListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemHoverBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="设备通信配置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="集中维护设备连接参数，支持 TCP Client、TCP Server、UDP 和 COM 四种通信方式。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,16">
                    <Button Content="新建"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="NewProfileButton_Click" />
                    <Button Content="复制"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DuplicateProfileButton_Click" />
                    <Button Content="删除"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DeleteProfileButton_Click" />
                    <Button Content="保存"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="SaveProfilesButton_Click" />
                </UniformGrid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ConfigListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="{Binding LocalName}" />
                                    <Border Width="100" HorizontalAlignment="Right"
                                            Margin="10,0,0,0"
                                            Padding="8,2"
                                            Background="{DynamicResource PrimaryButtonBrush}"
                                            BorderBrush="{DynamicResource SecondaryButtonBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock FontSize="11" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource AppContentTextBrush}"
                                                   Text="{Binding TypeDisplayName}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding Summary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.45*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前配置" />
                    <TextBlock Margin="0,8,0,0"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Text="{Binding SelectedProfile.TypeDescription}"
                   TextWrapping="Wrap" />
                    <TextBlock Margin="0,12,0,0"
                   FontWeight="SemiBold"
                   Text="{Binding SelectedProfile.Summary}"
                   TextWrapping="Wrap" />
                </StackPanel>
            </Border>


            <Grid Grid.Row="1"
                  Margin="0,16,0,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="连接参数" />
                        </DockPanel>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="配置名称" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                     Text="{Binding SelectedProfile.LocalName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="通信方式" />
                        <ComboBox Style="{StaticResource InputComboBoxStyle}" x:Name="communicationType"
                      ItemsSource="{Binding CommunicationTypes}"
                      ItemTemplate="{StaticResource CommunicationTypeItemTemplate}"
                      ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                      SelectedValue="{Binding SelectedProfile.Type, Mode=TwoWay}"
                      SelectedValuePath="Value" />


                        <StackPanel Visibility="{Binding ElementName=communicationType, Path=SelectedItem.Value, Converter={StaticResource ComparisonToVisibilityConvert}, ConverterParameter='TCPClient|TCPServer|Hsl'}">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="本地 IP 地址" />
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding SelectedProfile.LocalIPAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="本地端口" />
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding SelectedProfile.LocalPort, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ElementName=communicationType, Path=SelectedItem.Value, Converter={StaticResource ComparisonToVisibilityConvert}, ConverterParameter='TCPClient|UDP|Hsl'}">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="远程 IP 地址" />
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding SelectedProfile.RemoteIPAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="远程端口" />
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding SelectedProfile.RemotePort, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ElementName=communicationType, Path=SelectedItem.Value, Converter={StaticResource ComparisonToVisibilityConvert}, ConverterParameter='COM'}">
                            <DockPanel Margin="0,14,0,6">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Text="串口名称" />
                                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                        Content="刷新串口"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Click="RefreshPortsButton_Click" />
                            </DockPanel>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          IsEditable="True"
                          ItemsSource="{Binding PortNameOptions}"
                          ItemTemplate="{StaticResource PortNameItemTemplate}"
                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                          Text="{Binding SelectedProfile.PortName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="波特率" />
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding BaudRateOptions}"
                          ItemTemplate="{StaticResource SelectionOptionItemTemplate}"
                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                          SelectedValue="{Binding SelectedProfile.BaudRate, Mode=TwoWay}"
                          SelectedValuePath="Value" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="校验位" />
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding ParityOptions}"
                          ItemTemplate="{StaticResource SelectionOptionItemTemplate}"
                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                          SelectedValue="{Binding SelectedProfile.Parity, Mode=TwoWay}"
                          SelectedValuePath="Value" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="数据位" />
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding DataBitOptions}"
                          ItemTemplate="{StaticResource SelectionOptionItemTemplate}"
                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                          SelectedValue="{Binding SelectedProfile.DataBits, Mode=TwoWay}"
                          SelectedValuePath="Value" />

                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="停止位" />
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding StopBitOptions}"
                          ItemTemplate="{StaticResource SelectionOptionItemTemplate}"
                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                          SelectedValue="{Binding SelectedProfile.StopBits, Mode=TwoWay}"
                          SelectedValuePath="Value" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MinHeight="360"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="180"/>
                        </Grid.RowDefinitions>
                        <DockPanel LastChildFill="False"
                                   HorizontalAlignment="Stretch">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="通信测试" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Border Margin="0,0,10,0"
Padding="10,5"
Background="{DynamicResource TabCardBackgroundBrush}"
BorderBrush="{DynamicResource TabItemBorderBrush}"
BorderThickness="1"
CornerRadius="999">
                                    <TextBlock FontWeight="SemiBold"
       Foreground="{Binding ConnectionStatusBrush}"
       Text="{Binding ConnectionStatusText}" />
                                </Border>
                                <Button Content="测试连接"
Style="{StaticResource PrimaryActionButtonStyle}"
Click="TestConnectionButton_Click" />
                                <Button Content="断开"
Style="{StaticResource ActionButtonStyle}"
Click="CloseConnectionButton_Click" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Margin="0,8,0,0" Grid.Row="1"
Foreground="{DynamicResource AppMutedTextBrush}"
Text="测试会按当前配置创建通信对象；若为 TCP Server，会自动列出当前已连接客户端，可选择单发或全部发送。"
TextWrapping="Wrap" />
                        <StackPanel Grid.Row="2"
                                     Visibility="{Binding ElementName=communicationType, Path=SelectedItem.Value, Converter={StaticResource ComparisonToVisibilityConvert}, ConverterParameter='TCPServer'}">
                            <DockPanel Margin="0,14,0,6"
                                       LastChildFill="False">
                                <TextBlock Margin="0"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Text="当前已连接客户" />
                                <TextBlock DockPanel.Dock="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding ConnectedServerClientStatusText}" />
                            </DockPanel>
                            <ComboBox Style="{StaticResource ConnectedClientComboBoxStyle}"
                                      ItemsSource="{Binding ConnectedServerClients}"
                                      ItemTemplate="{StaticResource ConnectedClientItemTemplate}"
                                      ItemContainerStyle="{StaticResource ConnectedClientComboBoxItemStyle}"
                                      SelectedItem="{Binding SelectedServerClient, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="发送内容" Grid.Row="3"/>
                        <Grid Grid.Row="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
 Margin="0,0,10,0"
 Style="{StaticResource InputTextBoxStyle}"
 AcceptsReturn="True"
 HorizontalAlignment="Stretch"
 VerticalAlignment="Stretch"
 VerticalScrollBarVisibility="Auto"
 Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
Content="发送"
Style="{StaticResource PrimaryActionButtonStyle}"
Click="SendButton_Click" />
                            <Button Grid.Column="2"
Content="全部发送"
Style="{StaticResource ActionButtonStyle}"
 Visibility="{Binding ElementName=communicationType, Path=SelectedItem.Value, Converter={StaticResource ComparisonToVisibilityConvert}, ConverterParameter='TCPServer'}"
Click="SendAllButton_Click" />
                        </Grid>
                        <DockPanel Margin="0,14,0,6" LastChildFill="False" Grid.Row="5" >
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom"
   Style="{StaticResource FieldLabelStyle}"
   Margin="0"
   Text="接收 / 日志" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button
Content="清空"
Style="{StaticResource ActionButtonStyle}"
Click="ClearReceiveButton_Click" />
                            </StackPanel>
                            
                        </DockPanel>
                        <TextBox Grid.Row="6"
Padding="12"
AcceptsReturn="True"
IsReadOnly="True"
MinHeight="180"
HorizontalAlignment="Stretch"
VerticalAlignment="Stretch"
VerticalScrollBarVisibility="Auto"
HorizontalScrollBarVisibility="Auto"
FontFamily="Consolas"
FontSize="13"
Background="{DynamicResource TabCardBackgroundBrush}"
BorderBrush="{DynamicResource TabItemBorderBrush}"
BorderThickness="1"
Foreground="{DynamicResource AppContentTextBrush}"
Text="{Binding ReceiveText, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
