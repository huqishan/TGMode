<UserControl x:Class="ControlLibrary.ControlViews.Flowchart.FlowchartNodePanelView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ControlLibrary.Controls.FlowchartEditor.Control"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="FlowchartPaletteButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}"
                           Text="节点面板" />
                <TextBlock Margin="0,8,0,14"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="拖动组件到画布以创建节点。"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding NodeTemplates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FlowchartPaletteButtonStyle}"
                                    Tag="{Binding}"
                                    PreviewMouseLeftButtonDown="PaletteItem_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="PaletteItem_PreviewMouseLeftButtonUp"
                                    PreviewMouseMove="PaletteItem_PreviewMouseMove">
                                <DockPanel>
                                    <Border DockPanel.Dock="Left"
                                            Width="4"
                                            Height="22"
                                            Margin="0,0,10,0"
                                            Background="{Binding AccentBrush}"
                                            CornerRadius="2" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppContentTextBrush}"
                                               Text="{Binding DisplayName}" />
                                </DockPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <UniformGrid Columns="2" Margin="0,6,0,0">
                    <Button Content="导入"
                            Margin="0,10,10,0"
                            Command="{Binding OpenFlowchartCommand}"
                            CommandParameter="{Binding ElementName=PART_Editor}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="导出"
                            Margin="0,10,10,0"
                            Command="{Binding ExportFlowchartCommand}"
                            CommandParameter="{Binding ElementName=PART_Editor}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="运行"
                            Margin="0,10,10,0"
                            Command="{Binding ExecuteFlowchartCommand}"
                            CommandParameter="{Binding ElementName=PART_Editor}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Margin="0,10,10,0"
                            Command="{Binding PauseFlowchartCommand}"
                            CommandParameter="{Binding ElementName=PART_Editor}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
                                <Setter Property="Content" Value="暂停" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Content" Value="继续" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </UniformGrid>

                <Button Margin="0,10,10,0"
                        Content="停止"
                        Command="{Binding StopFlowchartCommand}"
                        CommandParameter="{Binding ElementName=PART_Editor}"
                        Style="{StaticResource ActionButtonStyle}" />

                <Separator Margin="0,14,0,12" />

                <TextBlock FontWeight="SemiBold"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="操作说明" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="拖动节点边缘的锚点以创建连线。"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="拖动画布空白区域可平移，滚动鼠标滚轮可缩放，按删除键可删除选中项。"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="双击处理块或判断块可打开同一套步骤编辑弹框。"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <controls:FlowchartEditorControl x:Name="PART_Editor"
                                         Grid.Column="2"
                                         Document="{Binding Document, ElementName=Root, Mode=TwoWay}" />
    </Grid>
</UserControl>
