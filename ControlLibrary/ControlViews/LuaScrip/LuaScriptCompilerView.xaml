<UserControl x:Class="ControlLibrary.ControlViews.LuaScrip.LuaScriptCompilerView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:luaEditor="clr-namespace:ControlLibrary.Controls.LuaScripEditor.Control"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                Background="{DynamicResource TabCardBackgroundBrush}"
                BorderBrush="{DynamicResource TabItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid MinHeight="280">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <Button Content="执行脚本"
                            Click="CompileLuaButton_Click"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                </DockPanel>

                <luaEditor:LuaScriptEditor x:Name="LuaScriptEditorControl"
                                           Grid.Row="2"
                                           ScriptText="{Binding ScriptText, ElementName=Root, Mode=OneWay}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="14"
                Background="{DynamicResource TabCardBackgroundBrush}"
                BorderBrush="{DynamicResource TabItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="&#x7f16;&#x8bd1;&#x7ed3;&#x679c;" />
                <TextBox Grid.Row="2"
                         Style="{StaticResource InputTextBoxStyle}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         Foreground="{Binding LuaEditorStatusBrush, ElementName=Root}"
                         Text="{Binding LuaCompileResultText, ElementName=Root, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
