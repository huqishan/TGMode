<UserControl x:Class="ControlLibrary.ControlViews.Protocol.ProtocolConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="ProtocolOptionItemTemplate">
            <TextBlock Foreground="{DynamicResource AppContentTextBrush}" Text="{Binding DisplayName}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="协议配置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="一个协议对应一种设备；协议下维护多条指令，每条指令有独立模板、占位符、校验和返回解析规则。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <searchBox:SearchBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     PlaceholderText="搜索协议配置..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,16">
                    <Button Content="新建"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="NewProfileButton_Click" />
                    <Button Content="复制"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DuplicateProfileButton_Click" />
                    <Button Content="删除"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="DeleteProfileButton_Click" />
                    <Button Content="保存"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="SaveProfilesButton_Click" />
                </UniformGrid>

                <ListBox Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding ProfilesView}"
                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MinHeight="130"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前协议" />
                            <Border HorizontalAlignment="Right"
Margin="16,0,0,0"
Padding="12,6"
VerticalAlignment="Top"
Background="{DynamicResource TabCardBackgroundBrush}"
BorderBrush="{DynamicResource TabItemBorderBrush}"
BorderThickness="1"
CornerRadius="999">
                                <TextBlock FontWeight="SemiBold"
       Foreground="{Binding PageStatusBrush}"
       Text="{Binding PageStatusText}" />
                            </Border>
                        </DockPanel>
                        
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="协议名称" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="{Binding SelectedProfile.Summary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  x:Name="ProtocolContentRegion"
                  ClipToBounds="True">
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="设备指令" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="新建指令"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Click="NewCommandButton_Click" />
                                <Button Content="复制指令"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="DuplicateCommandButton_Click" />
                                <Button Content="删除指令"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="DeleteCommandButton_Click" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,10"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="点击某条设备指令后，会从下侧滑出弹窗，显示基础设置、执行行为、协议模板与占位符、返回示例与解析规则。"
                                   TextWrapping="Wrap" />

                        <ListBox Grid.Row="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemsSource="{Binding SelectedProfile.Commands}"
                                 SelectedItem="{Binding SelectedProfile.SelectedCommand, Mode=TwoWay}"
                                 PreviewMouseLeftButtonUp="CommandListBox_PreviewMouseLeftButtonUp"
                                 ItemContainerStyle="{StaticResource ListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Grid x:Name="CommandDrawerHost"
                      Panel.ZIndex="10"
                      Opacity="0"
                      IsHitTestVisible="False">
                    <Border Background="#3A000000"
                            MouseLeftButtonDown="CommandDrawerBackdrop_MouseLeftButtonDown" />

                    <Border x:Name="CommandDrawerSheet"
                            Margin="0,56,0,0"
                            MaxHeight="{Binding ActualHeight, ElementName=ProtocolContentRegion}"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource DrawerBorderStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CommandDrawerTranslateTransform" Y="56" />
                        </Border.RenderTransform>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="指令编辑" />
                                <Button DockPanel.Dock="Right"
                                        Content="关闭"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="CloseCommandDrawerButton_Click" />
                            </DockPanel>

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,14,0,0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基础设置" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="协议名称" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="指令名称" />
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding SelectedProfile.CommandName, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="发送格式" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding PayloadFormats}"
                                                          SelectedValue="{Binding SelectedProfile.RequestFormat, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="返回格式" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding PayloadFormats}"
                                                          SelectedValue="{Binding SelectedProfile.ResponseFormat, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="鎵ц琛屼负" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="强制等待拼接时长(ms)" />
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding SelectedProfile.ReplyAggregationMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding ReplyWaitHelpText}"
                                                           TextWrapping="Wrap" />

                                                <CheckBox Margin="0,14,0,0"
                                                          Foreground="{DynamicResource AppContentTextBrush}"
                                                          Content="等待数据返回"
                                                          IsChecked="{Binding SelectedProfile.WaitForResponse, Mode=TwoWay}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding WaitForResponseHelpText}"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="CRC 鏍￠獙绫诲瀷" />
                                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                                          ItemTemplate="{StaticResource ProtocolOptionItemTemplate}"
                                                          ItemsSource="{Binding CrcModes}"
                                                          SelectedValue="{Binding SelectedProfile.CrcMode, Mode=TwoWay}"
                                                          SelectedValuePath="Value" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           Text="{Binding CrcHelpText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="16" />
                                                <RowDefinition Height="180" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       Text="协议模板与占位符" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,8,0,0"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding PlaceholderHelpText}"
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="协议内容模板" />
                                                <TextBox Grid.Row="1"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding SelectedProfile.ContentTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="占位符值" />
                                                <TextBox Grid.Row="1"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding SelectedProfile.PlaceholderValuesText, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button Grid.Column="1"
                                                        Grid.Row="1" Grid.RowSpan="2"
                                                        Content=">>" FontSize="20"
                                                        Style="{StaticResource ConvertButtonStyle}"
                                                        Click="GenerateCommandButton_Click" />

                                                <TextBlock Grid.Column="2"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Text="实际指令" />
                                                <TextBox Grid.Row="1"
                                                         Grid.Column="2"
                                                         x:Name="command"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         IsReadOnly="True"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding GeneratedCommandText, Mode=OneWay}" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Style="{StaticResource CardBorderStyle}"
                                            Visibility="{Binding SelectedProfile.WaitForResponse, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="16" />
                                                <RowDefinition Height="180" />
                                            </Grid.RowDefinitions>
                                            

                                            <TextBlock Grid.Row="0"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       Text="返回示例与解析规则" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="3"
                                                       Margin="0,8,0,0"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding ParseRuleHelpText}"
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="示例返回数据" />
                                                <TextBox Grid.Row="1"
                                                         Style="{StaticResource InputTextBoxStyle}"
                                                         AcceptsReturn="True"
                                                         FontFamily="Consolas"
                                                         VerticalAlignment="Stretch"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Text="{Binding SelectedProfile.SampleResponseText, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="解析规则" />
                                                <TextBox Grid.Row="1"
      Style="{StaticResource InputTextBoxStyle}"
      AcceptsReturn="True"
      FontFamily="Consolas"
      VerticalAlignment="Stretch"
      VerticalScrollBarVisibility="Auto"
      Text="{Binding SelectedProfile.ParseRulesText, UpdateSourceTrigger=PropertyChanged}" />

                                                <Button Grid.Row="1"
        Grid.Column="1" Grid.RowSpan="2"
        Content=">>" FontSize="20"
        Style="{StaticResource ConvertButtonStyle}"
        Click="ParseResultButton_Click" />

                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="解析结果" Grid.Row="0" Grid.Column="2"/>
                                                <TextBox Grid.Row="1" Grid.Column="2"
x:Name="result"
Style="{StaticResource InputTextBoxStyle}"
AcceptsReturn="True"
FontFamily="Consolas"
IsReadOnly="True"
VerticalAlignment="Stretch"
VerticalScrollBarVisibility="Auto"
Text="{Binding ParsedResultText, Mode=OneWay}" />
                                            </Grid>
                                            
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
