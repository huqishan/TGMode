<UserControl x:Class="ControlLibrary.Controls.FlowchartEditor.Control.FlowchartEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlLibrary.Controls.FlowchartEditor.Control"
             mc:Ignorable="d" 
             d:DesignHeight="600"
             d:DesignWidth="900"
             Focusable="True"
             Loaded="FlowchartEditorControl_Loaded"
             PreviewKeyDown="FlowchartEditorControl_PreviewKeyDown">
    <UserControl.Resources>
        <DrawingBrush x:Key="FlowchartGridBrush"
                      TileMode="Tile"
                      Stretch="None"
                      Viewbox="0,0,24,24"
                      ViewboxUnits="Absolute"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFFDFDFD" Geometry="M0,0 H24 V24 H0 Z" />
                    <GeometryDrawing>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="24,0" EndPoint="24,24" />
                                <LineGeometry StartPoint="0,24" EndPoint="24,24" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#FFE9E9E9" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="10">
        <Grid x:Name="Viewport"
              Background="#FFFDFDFD"
              ClipToBounds="True"
              AllowDrop="True"
              DragEnter="Viewport_DragOver"
              DragOver="Viewport_DragOver"
              Drop="Viewport_Drop"
              MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
              MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
              MouseMove="Viewport_MouseMove"
              MouseWheel="Viewport_MouseWheel"
              SizeChanged="Viewport_SizeChanged">
            <Canvas x:Name="WorkspaceCanvas"
                    Width="10000"
                    Height="10000"
                    Background="{StaticResource FlowchartGridBrush}">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="WorkspaceScaleTransform" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="WorkspaceTranslateTransform" />
                    </TransformGroup>
                </Canvas.RenderTransform>

                <Canvas x:Name="ConnectionsCanvas"
                        Width="10000"
                        Height="10000"
                        Background="{x:Null}" />
                <Canvas x:Name="NodesCanvas"
                        Width="10000"
                        Height="10000"
                        Background="{x:Null}" />
            </Canvas>
        </Grid>
    </Border>
</UserControl>
