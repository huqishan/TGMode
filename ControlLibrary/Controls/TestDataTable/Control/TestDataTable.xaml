<UserControl x:Class="ControlLibrary.Controls.TestDataTable.Control.TestDataTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Border Background="{DynamicResource TabCardBackgroundBrush}"
            BorderBrush="{DynamicResource TabItemBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="HeaderScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Focusable="False"
                          PreviewMouseWheel="HeaderScrollViewer_PreviewMouseWheel">
                <ContentControl x:Name="HeaderHost" />
            </ScrollViewer>

            <ScrollViewer x:Name="BodyScrollViewer"
                          Grid.Row="1"
                          MaxHeight="400"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                          ScrollChanged="BodyScrollViewer_ScrollChanged">
                <StackPanel x:Name="TablePanel"
                            SnapsToDevicePixels="True" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
