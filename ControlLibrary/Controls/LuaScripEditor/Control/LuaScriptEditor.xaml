<UserControl x:Class="ControlLibrary.Controls.LuaScripEditor.Control.LuaScriptEditor"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Border Background="{DynamicResource TabCardBackgroundBrush}"
            BorderBrush="{DynamicResource TabItemSelectedBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border MinWidth="48"
                    Padding="0,10,10,10"
                    CornerRadius="12,0,0,12"
                    Background="{DynamicResource TabItemBackgroundBrush}"
                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True">
                <TextBlock FontFamily="Consolas"
                           FontSize="20"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           LineHeight="24"
                           LineStackingStrategy="BlockLineHeight"
                           Text="{Binding LuaLineNumberText, ElementName=Root}"
                           TextAlignment="Right">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="LuaLineNumberOffsetTransform" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Border>

            <RichTextBox x:Name="LuaEditorRichTextBox"
                         Grid.Column="1"
                         Padding="10,10,0,10"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource LuaEditorPlainTextBrush}"
                         CaretBrush="{DynamicResource LuaEditorCaretBrush}"
                         SelectionBrush="{DynamicResource LuaEditorSelectionBrush}"
                         SelectionTextBrush="{DynamicResource LuaEditorSelectionTextBrush}"
                         FontFamily="Consolas"
                         FontSize="20"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.ScrollChanged="LuaEditorRichTextBox_ScrollChanged"
                         SelectionChanged="LuaEditorRichTextBox_SelectionChanged"
                         TextChanged="LuaEditorRichTextBox_TextChanged"
                         SpellCheck.IsEnabled="False">
                <FlowDocument PagePadding="0" />
            </RichTextBox>
        </Grid>
    </Border>
</UserControl>
