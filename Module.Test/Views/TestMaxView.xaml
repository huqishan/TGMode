<UserControl x:Class="Module.Test.Views.TestMaxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:testControls="clr-namespace:ControlLibrary.Controls.TestDataTable.Control;assembly=ControlLibrary"
             mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="StationNgBrush" Color="#D14343" />
        <SolidColorBrush x:Key="StationOkBrush" Color="#18A058" />
        <SolidColorBrush x:Key="StationIdleBrush" Color="#223044" />

        <Style x:Key="StationInnerPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="StationHeaderTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RunStateText}" Value="测试中">
                    <Setter Property="Foreground" Value="#102033" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StationPrimarySmallButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationSecondarySmallButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource StationPrimarySmallButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationSchemeComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Grid IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="10,3,8,3">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="方案" />
                                    <TextBlock Margin="0,1,0,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{Binding SelectedItem.WorkStepName, RelativeSource={RelativeSource TemplatedParent}, TargetNullValue=未选择方案}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Margin="0"
                                        Background="{DynamicResource TabItemBorderBrush}"
                                        CornerRadius="4">
                                    <Path Width="9"
                                          Height="5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4.5 5 L 9 0 Z"
                                          Fill="#BFD1E4" />
                                </Border>
                            </Grid>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource TabCardBackgroundBrush}"
                                        BorderBrush="{DynamicResource TabItemBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationSchemeComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkStepDotStyle" TargetType="{x:Type Ellipse}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Fill" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Stroke" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Result}" Value="OK">
                    <Setter Property="Fill" Value="{StaticResource StationOkBrush}" />
                    <Setter Property="Stroke" Value="{StaticResource StationOkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Result}" Value="NG">
                    <Setter Property="Fill" Value="{StaticResource StationNgBrush}" />
                    <Setter Property="Stroke" Value="{StaticResource StationNgBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                    <Setter Property="Stroke" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                    <Setter Property="StrokeThickness" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkStepTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Result}" Value="NG">
                    <Setter Property="Foreground" Value="{StaticResource StationNgBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkStepItemContainerStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                MinHeight="30"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="7,4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationLogTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="46" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="10,0,14,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppContentTextBrush}"
                                           Text="工位日志" />
                                <TabPanel Grid.Column="1"
                                          Margin="0,7,10,7"
                                          VerticalAlignment="Stretch"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1" />
                            </Grid>
                            <Border Grid.Row="1"
                                    Margin="10,0,10,10"
                                    Background="{DynamicResource TabCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StationLogTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="Chrome" Margin="0,0,6,0"
                                MinWidth="{TemplateBinding MinWidth}"
                                Height="{TemplateBinding Height}"
                                Background="{DynamicResource TabItemBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                ClipToBounds="False">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Header}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedForegroundBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Margin" Value="8,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="0,2" />
                        <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource TabCardBackgroundBrush}"
            BorderBrush="{DynamicResource TabItemBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{Binding StatusBrush}"
                    CornerRadius="8"
                    Padding="12,0">
                <DockPanel>
                    <TextBlock Style="{StaticResource StationHeaderTextStyle}"
           FontSize="18"
           FontWeight="SemiBold"
           Text="{Binding StationName}"
           TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="50,0,0,0"
           Style="{StaticResource StationHeaderTextStyle}"
           HorizontalAlignment="Center"
           FontSize="16"
           FontWeight="SemiBold"
           Text="{Binding RunStateText}" />


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock
Style="{StaticResource StationHeaderTextStyle}"
FontSize="12"
FontWeight="SemiBold"
Text="执行时间" />
                        <TextBlock Margin="16,0,0,0"
Style="{StaticResource StationHeaderTextStyle}"
FontFamily="Consolas"
FontSize="17"
FontWeight="SemiBold"
Text="{Binding ElapsedTimeText}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="282" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SchemeBorder"
                        Background="Transparent"
                        BorderBrush="{DynamicResource TabItemBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="0">
                    <ComboBox Style="{StaticResource StationSchemeComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource StationSchemeComboBoxItemStyle}"
                                  ItemsSource="{Binding ProfilesView}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  SelectedValuePath="SchemeId"
                                  ToolTip="{Binding SelectedProfile.WorkStepName}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource AppContentTextBrush}"
                                           Text="{Binding WorkStepName}"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="单步"
                            Command="{Binding SingleStepTestCommand}"
                            Style="{StaticResource StationPrimarySmallButtonStyle}" />
                    <Button Content="连续"
                            Command="{Binding ContinuousTestCommand}"
                            Style="{StaticResource StationPrimarySmallButtonStyle}" />
                    <Button Content="暂停"
                            Command="{Binding StopTestCommand}"
                            Style="{StaticResource StationSecondarySmallButtonStyle}" />
                    <Button Content="停止"
                            Command="{Binding StopTestCommand}"
                            Style="{StaticResource StationSecondarySmallButtonStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="182" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource StationInnerPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppContentTextBrush}"
                                   Text="工步流程" />
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Rectangle Width="1"
                                       Margin="17.5,10,0,0"
                                       HorizontalAlignment="Left"
                                       Fill="#2B4B68" />
                            <ListBox BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource WorkStepItemContainerStyle}"
                                     ItemsSource="{Binding WorkSteps}"
                                     SelectedItem="{Binding SelectedWorkStep, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse VerticalAlignment="Center"
                                                     Style="{StaticResource WorkStepDotStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource WorkStepTextStyle}"
                                                       Text="{Binding WorkStep}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource StationInnerPanelStyle}"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="{Binding CurrentWorkStepName}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="工步执行时间" />
                            <TextBlock Grid.Column="3"
                                       FontFamily="Consolas"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="{Binding CurrentWorkStepElapsedTimeText}" />
                        </Grid>

                        <testControls:TestDataTable Grid.Row="2"
                                                    ItemsSource="{Binding TestData}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3" Margin="0,10,0,0"
                    Style="{StaticResource StationInnerPanelStyle}"
                    Padding="0">
                <TabControl Style="{StaticResource StationLogTabControlStyle}"
                            ItemContainerStyle="{StaticResource StationLogTabItemStyle}">
                    <TabItem Header="运行日志">
                        <ListBox Style="{StaticResource LogListBoxStyle}" ItemsSource="{Binding RunningLogs}" />
                    </TabItem>
                    <TabItem Header="MES日志">
                        <ListBox Style="{StaticResource LogListBoxStyle}" ItemsSource="{Binding MesLogs}" />
                    </TabItem>
                    <TabItem Header="异常日志">
                        <ListBox Style="{StaticResource LogListBoxStyle}" ItemsSource="{Binding ExceptionLogs}" />
                    </TabItem>
                    <TabItem Header="功能日志">
                        <ListBox Style="{StaticResource LogListBoxStyle}" ItemsSource="{Binding FunctionLogs}" />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Border>
</UserControl>
