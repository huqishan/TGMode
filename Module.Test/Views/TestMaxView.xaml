<UserControl x:Class="Module.Test.Views.TestMaxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:testControls="clr-namespace:ControlLibrary.Controls.TestDataTable.Control;assembly=ControlLibrary"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="BarcodeStripeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="3" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CornerRadius" Value="1.5" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style x:Key="CompactTestStepButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestStepButtonStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestContinuousButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestContinuousButtonStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="6,6,0,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestStopButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestStopButtonStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="6,6,0,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestStatusPanelStyle"
               TargetType="{x:Type Border}"
               BasedOn="{StaticResource TestStatusPanelStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="200" />
            <Setter Property="Padding" Value="16,0" />
        </Style>
    </UserControl.Resources>

    <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <StackPanel>
                        <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="{Binding StationName}"
                                       TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DockPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Command="{Binding SingleStepTestCommand}"
        Style="{StaticResource CompactTestStepButtonStyle}"
        ToolTip="{DynamicResource 单步测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="20" Height="20" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                     StrokeThickness="4" />
                                <Path Width="9"
                  Height="9"
                  Data="M 7 4 L 11 4 L 6 13 L 7 8 L 3 8 Z"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  Stretch="Uniform" />
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Text="{DynamicResource 单步}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ContinuousTestCommand}"
        Style="{StaticResource CompactTestContinuousButtonStyle}"
        ToolTip="{DynamicResource 连续测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="20" Height="20" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <Path Width="14"
                  Height="9"
                  Data="M 1 6 L 5 6 L 7 2 L 11 10 L 13 6 L 17 6"
                  Stroke="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                  StrokeThickness="2"
                  Stretch="Fill" />
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Text="{DynamicResource 连续}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding StopTestCommand}"
        Style="{StaticResource CompactTestStopButtonStyle}"
        ToolTip="{DynamicResource 停止测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Rectangle Width="14"
                   Height="14"
                   Margin="0,0,8,0"
                   RadiusX="3"
                   RadiusY="3"
                   VerticalAlignment="Center"
                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Text="{DynamicResource 停止}" />
                        </StackPanel>
                    </Button>

                    <Border Margin="6,6,0,0" Style="{StaticResource CompactTestStatusPanelStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                   Style="{StaticResource TestStatusTextStyle}"
                   FontSize="18"
                   Text="{Binding RunStateText}" />
                            <TextBlock Grid.Column="1"
                   Style="{StaticResource TestElapsedTextStyle}"
                   FontSize="16"
                   Text="{Binding ElapsedTimeText}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Width="320" Padding="10,10,0,10" Margin="16,0,0,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                                <Border Height="24" Style="{StaticResource BarcodeStripeStyle}" />
                                <Border Height="32" Style="{StaticResource BarcodeStripeStyle}" />
                                <Border Height="18" Style="{StaticResource BarcodeStripeStyle}" />
                                <Border Height="34" Style="{StaticResource BarcodeStripeStyle}" />
                                <Border Height="22" Style="{StaticResource BarcodeStripeStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource AppMutedTextBlockStyle}" Text="{DynamicResource 产品条码}" />
                                <TextBlock Margin="0,6,0,0"
                       FontFamily="Consolas"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppContentTextBrush}"
                       Text="{Binding ProductBarcode}"
                       TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,12,0,0">
            <TabControl Style="{DynamicResource SchemeParameterTabControlStyle}">
                <TabItem Header="测试信息">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <ListBox
BorderThickness="0"
Background="Transparent"
ItemContainerStyle="{StaticResource ListBoxItemStyle}"
ItemsSource="{Binding WorkStep}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                      Margin="10,0,0,0"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource AppMutedTextBrush}"
                      Text="{Binding Result}" />
                                            <TextBlock FontSize="15"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource AppContentTextBrush}"
                      Text="{Binding WorkStep}"
                      TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                  Foreground="{DynamicResource AppMutedTextBrush}"
                  Text="{Binding Name}"
                  TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <testControls:TestDataTable Grid.Column="1" ItemsSource="{Binding TestData}" />
                    </Grid>

                </TabItem>
            </TabControl>

        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border MinHeight="200" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,12,0,0">
                <TabControl Style="{DynamicResource SchemeParameterTabControlStyle}">
                    <TabItem Header="运行日志">

                    </TabItem>
                    <TabItem Header="异常日志">

                    </TabItem>
                    <TabItem Header="MES日志">

                    </TabItem>
                    <TabItem Header="功能日志">

                    </TabItem>
                </TabControl>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="6,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource MES 工艺列表}" />
                    <DataGrid Margin="0,6,0,0" Grid.Row="1" ItemsSource="{Binding ProfilesView}">
                        
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
