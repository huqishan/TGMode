<UserControl x:Class="Module.Test.Views.TestMinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Module.Test.ViewModels"
             xmlns:testControls="clr-namespace:ControlLibrary.Controls.TestDataTable.Control;assembly=ControlLibrary"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TestMinViewModel, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <Style x:Key="BarcodeStripeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="3" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CornerRadius" Value="1.5" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource AppCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="15"
            SnapsToDevicePixels="True">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <Grid
      Width="42"
      Height="42"
      VerticalAlignment="Center">
                    <Ellipse Fill="{DynamicResource TabItemBackgroundBrush}" />
                    <Ellipse Width="28"
             Height="28"
             Fill="{DynamicResource BoardBrush}"
             Stroke="{Binding StatusBrush}"
             StrokeThickness="2"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
                    <Ellipse Width="11"
             Height="11"
             Fill="{Binding StatusBrush}"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
                </Grid>
                <StackPanel Margin="8,0,0,0"
            VerticalAlignment="Center">
                    <TextBlock FontSize="18"
               FontWeight="SemiBold"
               Foreground="{DynamicResource AppContentTextBrush}"
               Text="{Binding StationName}"
               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,3,0,0"
               FontSize="12"
               Foreground="{DynamicResource AppMutedTextBrush}"
               Text="{Binding SchemeName}"
               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="方案选择" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource AppMutedTextBlockStyle}" Text="集中维护 MES 接口、调用方式、示例报文和测试返回结果。" TextWrapping="Wrap"  />
                            </StackPanel>
                            <StackPanel Margin="0,6,0,0">
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
Margin="12,0,0,0"
Content="刷新"
Command="{Binding RefreshProductsCommand}"
Style="{StaticResource ActionButtonStyle}" />
                                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
  Height="46"
  ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
  ItemsSource="{Binding ProductOptions}"
  SelectedItem="{Binding SelectedProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <ListBox Grid.Row="1" Margin="0,16,0,0"
     BorderThickness="0"
     Background="Transparent"
     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
     ItemsSource="{Binding ProfilesView}"
     SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppContentTextBrush}"
                           Text="{Binding WorkStepName}" />
                                            
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                       Foreground="{DynamicResource AppMutedTextBrush}"
                       Text="{Binding Summary}"
                       TextWrapping="Wrap" />

                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid x:Name="buttons">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding SingleStepTestCommand}"
                                    Style="{StaticResource TestStepButtonStyle}"
                                    ToolTip="&#x5355;&#x6B65;&#x6D4B;&#x8BD5;">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="28"
                                          Height="28"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center">
                                        <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                 StrokeThickness="5" />
                                        <Path Width="12"
                                              Height="12"
                                              Data="M 7 4 L 11 4 L 6 13 L 7 8 L 3 8 Z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Stretch="Uniform" />
                                    </Grid>
                                    <TextBlock Style="{StaticResource TestOperationButtonTextStyle}"
                                               Text="&#x5355;&#x6B65;&#x6D4B;&#x8BD5;" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Command="{Binding ContinuousTestCommand}"
                                    Style="{StaticResource TestContinuousButtonStyle}"
                                    ToolTip="&#x8FDE;&#x7EED;&#x6D4B;&#x8BD5;">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="28"
                                          Height="28"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center">
                                        <Ellipse Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <Path Width="18"
                                              Height="11"
                                              Data="M 1 6 L 5 6 L 7 2 L 11 10 L 13 6 L 17 6"
                                              Stroke="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeThickness="2.2"
                                              Stretch="Fill" />
                                    </Grid>
                                    <TextBlock Style="{StaticResource TestOperationButtonTextStyle}"
                                               Text="&#x8FDE;&#x7EED;&#x6D4B;&#x8BD5;" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding StopTestCommand}"
                                    Style="{StaticResource TestStopButtonStyle}"
                                    ToolTip="&#x505C;&#x6B62;&#x6D4B;&#x8BD5;">
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="17"
                                               Height="17"
                                               Margin="0,0,14,0"
                                               RadiusX="3"
                                               RadiusY="3"
                                               VerticalAlignment="Center"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Style="{StaticResource TestOperationButtonTextStyle}"
                                               Text="&#x505C;&#x6B62;&#x6D4B;&#x8BD5;" />
                                </StackPanel>
                            </Button>

                            <Border Grid.Column="3"
                                    Style="{StaticResource TestStatusPanelStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource TestStatusTextStyle}"
                                               Text="{Binding RunStateText}" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource TestElapsedTextStyle}"
                                               Text="{Binding ElapsedTimeText}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <testControls:TestDataTable x:Name="testData" Margin="0,8,0,0"
                            Grid.Row="1"
                            ItemsSource="{Binding TestData}" />
                    </Grid>
                </Border>
            </Grid>
            















           
