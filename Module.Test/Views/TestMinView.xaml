<UserControl x:Class="Module.Test.Views.TestMinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Module.Test.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.Resources>
            <Style x:Key="StatusValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="StatusCaptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="StatusPanelStyle" TargetType="Border">
                <Setter Property="Padding" Value="18" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="112" />
            </Style>
        </Grid.Resources>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18"
                    CornerRadius="8"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource AppCardBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="当前测试状态"
                                   Style="{StaticResource StatusCaptionTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding StatusBrush}"
                                   Text="{Binding TestStatus}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Margin="24,0,0,0"
                               VerticalAlignment="Top"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="{Binding LastUpdatedText}" />
                </Grid>
            </Border>

            <UniformGrid Grid.Row="2" Columns="2" Rows="2">
                <Border Margin="0,0,8,8" Style="{StaticResource StatusPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="当前工位名称" Style="{StaticResource StatusCaptionTextStyle}" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource StatusValueTextStyle}"
                                   Text="{Binding StationName}" />
                    </StackPanel>
                </Border>

                <Border Margin="8,0,0,8" Style="{StaticResource StatusPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="产品条码" Style="{StaticResource StatusCaptionTextStyle}" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource StatusValueTextStyle}"
                                   Text="{Binding ProductBarcode}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,8,8,0" Style="{StaticResource StatusPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="当前测试方案" Style="{StaticResource StatusCaptionTextStyle}" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource StatusValueTextStyle}"
                                   Text="{Binding SchemeName}" />
                    </StackPanel>
                </Border>

                <Border Margin="8,8,0,0" Style="{StaticResource StatusPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="当前产品" Style="{StaticResource StatusCaptionTextStyle}" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource StatusValueTextStyle}"
                                   Text="{Binding ProductName}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>
