<UserControl x:Class="Module.Test.Views.TestMinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:testControls="clr-namespace:ControlLibrary.Controls.TestDataTable.Control;assembly=ControlLibrary"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="BarcodeStripeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="3" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Background" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CornerRadius" Value="1.5" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style x:Key="CompactTestStepButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestStepButtonStyle}">
            <Setter Property="Height" Value="56" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestContinuousButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestContinuousButtonStyle}">
            <Setter Property="Height" Value="56" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestStopButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource TestStopButtonStyle}">
            <Setter Property="Height" Value="56" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="CompactTestStatusPanelStyle"
               TargetType="{x:Type Border}"
               BasedOn="{StaticResource TestStatusPanelStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="16,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" MinWidth="460" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="104" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="{Binding StationName}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0"
                            Style="{StaticResource CompactTestStatusPanelStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TestStatusTextStyle}"
                                       FontSize="18"
                                       Text="{Binding RunStateText}" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource TestElapsedTextStyle}"
                                       FontSize="16"
                                       Text="{Binding ElapsedTimeText}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Height="24" Style="{StaticResource BarcodeStripeStyle}" />
                        <Border Height="32" Style="{StaticResource BarcodeStripeStyle}" />
                        <Border Height="18" Style="{StaticResource BarcodeStripeStyle}" />
                        <Border Height="34" Style="{StaticResource BarcodeStripeStyle}" />
                        <Border Height="22" Style="{StaticResource BarcodeStripeStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource AppMutedTextBlockStyle}" Text="{DynamicResource 产品条码}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="Consolas"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppContentTextBrush}"
                                   Text="{Binding ProductBarcode}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding SingleStepTestCommand}"
                            Style="{StaticResource CompactTestStepButtonStyle}"
                            ToolTip="{DynamicResource 单步测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="20" Height="20" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         StrokeThickness="4" />
                                <Path Width="9"
                                      Height="9"
                                      Data="M 7 4 L 11 4 L 6 13 L 7 8 L 3 8 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform" />
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource 单步}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding ContinuousTestCommand}"
                            Style="{StaticResource CompactTestContinuousButtonStyle}"
                            ToolTip="{DynamicResource 连续测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="20" Height="20" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Ellipse Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <Path Width="14"
                                      Height="9"
                                      Data="M 1 6 L 5 6 L 7 2 L 11 10 L 13 6 L 17 6"
                                      Stroke="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="2"
                                      Stretch="Fill" />
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource 连续}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Command="{Binding StopTestCommand}"
                            Style="{StaticResource CompactTestStopButtonStyle}"
                            ToolTip="{DynamicResource 停止测试}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Rectangle Width="14"
                                       Height="14"
                                       Margin="0,0,8,0"
                                       RadiusX="3"
                                       RadiusY="3"
                                       VerticalAlignment="Center"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource 停止}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource 工步列表}" />

                    <ListBox Grid.Row="1"
                             Margin="0,12,0,0"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                             ItemsSource="{Binding WorkStep}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="10,0,0,0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding Result}" />
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppContentTextBrush}"
                                                   Text="{Binding WorkStep}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource 结果列表}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{Binding SchemeName}" />
                </StackPanel>

                <testControls:TestDataTable Grid.Row="1"
                                            Margin="0,16,0,0"
                                            ItemsSource="{Binding TestData}" />
            </Grid>
        </Border>

        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource MES 工艺列表}" />

                    <ListBox Grid.Row="1"
                             Margin="0,6,0,0"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                             ItemsSource="{Binding ProfilesView}"
                             SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppContentTextBrush}"
                                               Text="{Binding WorkStepName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="{Binding Summary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource 运行日志}" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,16,0,0"
                             Style="{StaticResource InputTextBoxStyle}"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.Text>
                            <MultiBinding Mode="OneWay" StringFormat="状态：{0}&#x0a;条码：{1}&#x0a;工步：{2}&#x0a;耗时：{3}">
                                <Binding Path="TestStatus" Mode="OneWay" />
                                <Binding Path="ProductBarcode" Mode="OneWay" />
                                <Binding Path="SchemeName" Mode="OneWay" />
                                <Binding Path="ElapsedTimeText" Mode="OneWay" />
                            </MultiBinding>
                        </TextBox.Text>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
