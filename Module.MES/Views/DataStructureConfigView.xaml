<UserControl x:Class="Module.MES.Views.DataStructureConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="ConfigListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemHoverBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="数据结构配置" />
                    <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" Style="{StaticResource AppMutedTextBlockStyle}" Text="支持多配置、JSON/XML、MESCode、ClientCode、数据类型、默认值与 XML 命名空间。" />

                </StackPanel>
                <searchBox:SearchBox Grid.Row="1"
   Margin="0,16,0,0"
   PlaceholderText="搜索结构配置..."
   Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,16">
                    <Button Content="新增"
Click="AddProfile_Click"
Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
Click="DuplicateProfile_Click"
Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
Click="DeleteProfile_Click"
Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
Click="SaveProfiles_Click"
Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>
                <ListBox Grid.Row="3"
         BorderThickness="0"
         Background="Transparent"
         ItemContainerStyle="{StaticResource ConfigListBoxItemStyle}"
         ItemsSource="{Binding Profiles}"
         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppContentTextBrush}"
                               Text="{Binding Name}" />
                                    <Border DockPanel.Dock="Right"
                            Margin="10,0,0,0" Width="100"
                            Padding="8,2"
                            Background="{DynamicResource PrimaryButtonBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                                        <TextBlock Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding Name}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="{Binding Summary}"
                           TextWrapping="Wrap" />

                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

        </Border>

        <Grid Grid.Column="2"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    MinHeight="130"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前结构" />
                            <Border HorizontalAlignment="Right"
Margin="16,0,0,0"
Padding="12,6"
VerticalAlignment="Top"
Background="{DynamicResource TabCardBackgroundBrush}"
BorderBrush="{DynamicResource TabItemBorderBrush}"
BorderThickness="1"
CornerRadius="999">
                                <TextBlock FontWeight="SemiBold"
       Foreground="{Binding PageStatusBrush}"
       Text="{Binding PageStatusText}" />
                            </Border>
                        </DockPanel>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="结构名称" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding SelectedProfile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="{Binding SelectedProfile.Summary}"
                                   TextWrapping="Wrap" />

                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
         MinHeight="130"
         HorizontalAlignment="Stretch"
         VerticalAlignment="Stretch"
         Style="{StaticResource CardBorderStyle}">
                <TreeView Background="{DynamicResource TabItemBackgroundBrush}" BorderThickness="0"></TreeView>
            </Border>
        </Grid>
    </Grid>
</UserControl>

