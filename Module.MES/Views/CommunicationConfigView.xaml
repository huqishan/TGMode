<UserControl x:Class="Module.MES.Views.CommunicationConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Module.MES.ViewModels"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1600">
    <UserControl.DataContext>
        <vm:CommunicationConfigViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="通讯配置" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="维护 MES 接口调用的公共通讯参数。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,16">
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="重新读取"
                            Command="{Binding ReloadCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="默认值"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <StackPanel Grid.Row="3">
                    <Border Padding="14"
                            Background="{DynamicResource TabCardBackgroundBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppContentTextBrush}"
                                       Text="当前摘要" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding TimeoutSummary}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding RetrySummary}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel LastChildFill="False">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="公共参数" />
                    <Border DockPanel.Dock="Right"
                            Padding="12,6"
                            Background="{DynamicResource TabCardBackgroundBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{Binding PageStatusBrush}"
                                   Text="{Binding PageStatusText}" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="接口超时时间（秒）" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding TimeoutText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="用于 WebApi、WebService、TCP Client 等 MES 接口等待返回的超时时间。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="重传次数" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding RetransmissionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="当接口返回超时信息时，按该次数重新发送。0 表示不重传。"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="配置文件" />
                    <TextBox Margin="0,12,0,0"
                             Style="{StaticResource InputTextBoxStyle}"
                             IsReadOnly="True"
                             Text="{Binding ConfigFilePath, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
