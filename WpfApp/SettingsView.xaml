<UserControl x:Class="WpfApp.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="SettingsRadioButtonStyle"
               TargetType="{x:Type RadioButton}"
               BasedOn="{StaticResource {x:Type RadioButton}}">
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <Border Width="650"
                    Margin="0,0,0,18"
                    Padding="28"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource TabItemBackgroundBrush}"
                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock Style="{StaticResource AppTitleTextBlockStyle}"
                               Text="{DynamicResource SettingsThemeTitle}" />

                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{DynamicResource SettingsThemeDescription}"
                               TextWrapping="Wrap" />

                    <StackPanel x:Name="ThemePanel" Margin="0,18,0,0">
                        <RadioButton Checked="OnThemeRadioButtonChecked"
                                     Content="{DynamicResource SettingsThemeDark}"
                                     GroupName="AppTheme"
                                     Style="{StaticResource SettingsRadioButtonStyle}"
                                     Tag="Dark" />
                        <RadioButton Checked="OnThemeRadioButtonChecked"
                                     Content="{DynamicResource SettingsThemeLight}"
                                     GroupName="AppTheme"
                                     Style="{StaticResource SettingsRadioButtonStyle}"
                                     Tag="Light" />
                    </StackPanel>

                    <Border Height="1"
                            Margin="0,24,0,22"
                            Background="{DynamicResource TabItemBorderBrush}" />

                    <TextBlock Style="{StaticResource AppTitleTextBlockStyle}"
                               Text="{DynamicResource SettingsLanguageTitle}" />

                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{DynamicResource SettingsLanguageDescription}"
                               TextWrapping="Wrap" />

                    <ComboBox x:Name="LanguageComboBox"
                              Width="240"
                              Margin="0,18,0,0"
                              HorizontalAlignment="Left"
                              FontSize="14"
                              MaxDropDownHeight="240"
                              DisplayMemberPath="DisplayName"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              SelectedValuePath="Key"
                              Style="{StaticResource InputComboBoxStyle}"
                              SelectionChanged="OnLanguageSelectionChanged" />
                </StackPanel>
            </Border>

            <Border Width="650" Height="400"
                    Padding="28"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource TabItemBackgroundBrush}"
                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Margin="0,0,10,0"
                                    Click="AddStationButton_Click"
                                    Content="{DynamicResource SettingsAddStation}"
                                    Style="{StaticResource ActionButtonStyle}" />
                            <Button Click="SaveStationsButton_Click"
                                    Content="{DynamicResource SettingsSaveStations}"
                                    Style="{StaticResource PrimaryActionButtonStyle}" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource AppTitleTextBlockStyle}"
                                   Text="{DynamicResource SettingsTestStationsTitle}" />
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{DynamicResource SettingsTestStationsDescription}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2"
                               Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Text="{Binding TestStationSummaryText}" />

                    <TextBlock Grid.Row="3"
                               Margin="0,6,0,16"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="{Binding TestStationStatusText}"
                               TextWrapping="Wrap" />

                    <DataGrid Grid.Row="4"
                              x:Name="TestStationsDataGrid"
                              Margin="0,4,0,0" HorizontalScrollBarVisibility="Disabled"
                              ItemsSource="{Binding TestStations}"
                              Style="{StaticResource ColumnsDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource SettingsTestStationNameLabel}"
                                                Width="*"
                                                Binding="{Binding StationName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                ElementStyle="{StaticResource CellTextBlockStyle}"
                                                EditingElementStyle="{StaticResource CellTextBoxStyle}" />

                            <DataGridTemplateColumn Header="{DynamicResource SettingsTestStationSchemeMatchLabel}"
                                                    Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSchemeMatchingEnabled, Mode=TwoWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource Action}"
                                                    Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Center"
                                                Click="DeleteStationButton_Click"
                                                Content="{DynamicResource SettingsDeleteStation}"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Tag="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
