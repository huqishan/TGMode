<UserControl x:Class="WpfApp.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="SettingsRadioButtonStyle"
               TargetType="{x:Type RadioButton}"
               BasedOn="{StaticResource {x:Type RadioButton}}">
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource TabCardBackgroundBrush}">
        <Border MaxWidth="520"
                Padding="28"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{DynamicResource TabItemBackgroundBrush}"
                BorderBrush="{DynamicResource TabItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock Style="{StaticResource AppTitleTextBlockStyle}"
                           Text="Theme Mode" />

                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource AppMutedTextBlockStyle}"
                           Text="Switch the application color theme. Dark keeps the current background and text colors."
                           TextWrapping="Wrap" />

                <StackPanel x:Name="ThemePanel" Margin="0,18,0,0">
                    <RadioButton Checked="OnThemeRadioButtonChecked"
                                 Content="Dark"
                                 GroupName="AppTheme"
                                 Style="{StaticResource SettingsRadioButtonStyle}"
                                 Tag="Dark" />
                    <RadioButton Checked="OnThemeRadioButtonChecked"
                                 Content="Light"
                                 GroupName="AppTheme"
                                 Style="{StaticResource SettingsRadioButtonStyle}"
                                 Tag="Light" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
