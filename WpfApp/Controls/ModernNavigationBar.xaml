<UserControl x:Class="WpfApp.Controls.ModernNavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="320">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="PaneBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D50D1828" Offset="0" />
            <GradientStop Color="#CC0A1320" Offset="0.58" />
            <GradientStop Color="#BF081019" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SelectedItemBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2E63E6FF" Offset="0" />
            <GradientStop Color="#1A39B9FF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#F4F8FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#28D7EFFF" />
                                <Setter TargetName="Chrome" Property="Background" Value="#12253B53" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="22"
            Background="{StaticResource PaneBrush}"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            CornerRadius="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header area that mirrors the NavigationView pane title hierarchy. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="52"
                        Height="52"
                        CornerRadius="18"
                        Background="#14355678"
                        BorderBrush="#2ED8F1FF"
                        BorderThickness="1">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#F4F8FF"
                               Text="W" />
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="PaneTitleText"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F8FBFF"
                               Text="WpfApp" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#8CB1CF"
                               FontSize="12"
                               Text="Modern Navigation" />
                </StackPanel>
            </Grid>

            <!-- Search box that filters items by title and description. -->
            <Border Grid.Row="1"
                    Margin="0,22,0,18"
                    Padding="14,0"
                    Height="46"
                    Background="#0E223548"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons"
                               Foreground="#9AB6CF"
                               FontSize="14"
                               Text="&#xE721;" />

                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <TextBox x:Name="SearchTextBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F4F8FF"
                                 CaretBrush="#F4F8FF"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 TextChanged="SearchTextBox_TextChanged" />
                        <TextBlock x:Name="SearchPlaceholderText"
                                   VerticalAlignment="Center"
                                   Foreground="#7190AD"
                                   FontSize="14"
                                   IsHitTestVisible="False"
                                   Text="Search" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Dynamic item host rebuilt from the current filter result. -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ItemsHost" />
            </ScrollViewer>

            <!-- Fixed settings entry at the bottom, similar to NavigationView. -->
            <Button x:Name="SettingsButton"
                    Grid.Row="3"
                    Margin="0,18,0,0"
                    Style="{StaticResource NavButtonStyle}"
                    Click="SettingsButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="18"
                               Foreground="#F4F8FF"
                               Text="&#xE713;" />

                    <TextBlock Grid.Column="1"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#F4F8FF"
                               Text="Settings" />
                </Grid>
            </Button>
        </Grid>
    </Border>
</UserControl>
