<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>
    <Style x:Key="DrawerBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>
</ResourceDictionary>