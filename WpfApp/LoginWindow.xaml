<Window x:Class="WpfApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录"
        Width="500"
        Height="540"
        MinWidth="500"
        MinHeight="540"
        MaxWidth="500"
        MaxHeight="540"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    <Window.Resources>
        <DropShadowEffect x:Key="LoginWindowShadow"
                          BlurRadius="28"
                          Opacity="0.22"
                          ShadowDepth="8"
                          Color="#111827" />

        <Style x:Key="LoginCaptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabClosePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginCloseButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource LoginCaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoginInputTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemHoverBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource TabItemHoverBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Margin="18"
                Background="{DynamicResource BoardBrush}"
                BorderBrush="{DynamicResource TabItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Effect="{StaticResource LoginWindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBrush}"
                        CornerRadius="22,22,0,0"
                        MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
                    <DockPanel Margin="16,8,10,8"
                               LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="10"
                                    Height="10"
                                    Margin="0,0,8,0"
                                    Background="{DynamicResource PrimaryButtonBrush}"
                                    CornerRadius="5" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="WpfApp" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <Button Content="-"
                                    Click="MinimizeButton_Click"
                                    Style="{StaticResource LoginCaptionButtonStyle}" />
                            <Button Content="X"
                                    Click="CloseCaptionButton_Click"
                                    Style="{StaticResource LoginCloseButtonStyle}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1"
                      Margin="42,34,42,38">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Text="登录" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource AppMutedTextBlockStyle}"
                                   Text="请输入账号和密码进入系统。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Margin="0,0,0,8"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="账号" />
                        <TextBox x:Name="AccountInput"
                                 Style="{StaticResource LoginInputTextBoxStyle}"
                                 Text="10086" />
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Margin="0,0,0,8"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="密码" 
                                   />
                        <PasswordBox x:Name="PasswordInput"
                                     KeyDown="PasswordInput_KeyDown"
                                     Style="{StaticResource LoginPasswordBoxStyle}" 
                                     />
                    </StackPanel>

                    <Border Grid.Row="6"
                            Padding="12,9"
                            Background="{DynamicResource TabCardBackgroundBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{Binding StatusBrush}"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Button Grid.Row="8"
                            Content="登录"
                            IsDefault="True"
                            Click="LoginButton_Click"
                            Style="{StaticResource LoginPrimaryButtonStyle}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
