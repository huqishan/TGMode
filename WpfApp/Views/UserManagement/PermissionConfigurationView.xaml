<UserControl x:Class="WpfApp.Views.UserManagement.PermissionConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <Style x:Key="PermissionDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PermissionDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PermissionDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PermissionCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>

        <Style x:Key="PermissionExpandButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PermissionCellTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="权限配置" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource AppMutedTextBlockStyle}"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <ComboBox Width="190"
                              Margin="0,0,10,10"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              ItemsSource="{Binding PermissionRoleOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedRoleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="全部显示"
                            Click="ShowAllButton_Click"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="全部可点"
                            Click="EnableAllButton_Click"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="全部展开"
                            Click="ExpandAllButton_Click"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="全部折叠"
                            Click="CollapseAllButton_Click"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="重新扫描"
                            Click="ReloadButton_Click"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Click="SaveButton_Click"
                            IsEnabled="{Binding CanEditPermissions}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Border Padding="12,6"
                            VerticalAlignment="Top"
                            Background="{DynamicResource TabCardBackgroundBrush}"
                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{Binding StatusBrush}"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <DataGrid ItemsSource="{Binding PermissionRows}"
                          IsEnabled="{Binding CanEditPermissions}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          AlternationCount="2"
                          RowHeight="42"
                          Background="{DynamicResource TabCardBackgroundBrush}"
                          Foreground="{DynamicResource AppContentTextBrush}"
                          ColumnHeaderStyle="{StaticResource PermissionDataGridHeaderStyle}"
                          RowStyle="{StaticResource PermissionDataGridRowStyle}"
                          CellStyle="{StaticResource PermissionDataGridCellStyle}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="界面 / 弹窗 / 按钮"
                                                Width="280"
                                                MinWidth="220"
                                                MaxWidth="360">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="{Binding IndentWidth}" />
                                        <Button Grid.Column="1"
                                                Content="{Binding ExpandGlyph}"
                                                Click="ToggleNodeButton_Click"
                                                IsEnabled="{Binding HasChildren}"
                                                Tag="{Binding}"
                                                Style="{StaticResource PermissionExpandButtonStyle}" />
                                        <Border Grid.Column="2"
                                                MinWidth="46"
                                                Margin="0,0,10,0"
                                                Padding="8,3"
                                                Background="{DynamicResource TabCardBackgroundBrush}"
                                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding KindDisplayName}" />
                                        </Border>
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="标识"
                                            Width="150"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource PermissionCellTextBlockStyle}"
                                            Binding="{Binding ElementIdentifier}" />

                        <DataGridCheckBoxColumn Header="显示"
                                                Width="72"
                                                ElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                EditingElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                Binding="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridCheckBoxColumn Header="使能"
                                                Width="72"
                                                ElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                EditingElementStyle="{StaticResource PermissionCheckBoxStyle}"
                                                Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <DataGridTextColumn x:Name="SourceColumn"
                                            Header="来源"
                                            Width="1.2*"
                                            MinWidth="300"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource PermissionCellTextBlockStyle}"
                                            Binding="{Binding SourcePath}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
