<UserControl x:Class="Module.Business.Views.SchemeConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             xmlns:vm="clr-namespace:Module.Business.ViewModels"
             xmlns:businessViews="clr-namespace:Module.Business.Views.Controls.Views"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.Resources>
        <Style x:Key="BusinessInputTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BusinessComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>

        <Style x:Key="SchemeStepComboBoxStyle"
               TargetType="{x:Type ComboBox}"
               BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </UserControl.Resources>
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="方案配置" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding SchemeCountText}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="维护方案、工步顺序与步骤内容。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <searchBox:SearchBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     PlaceholderText="搜索方案配置..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="2" Columns="6" Margin="0,16,0,16">
                    <Button Content="新建"
                            Command="{Binding NewSchemeCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
                            Command="{Binding DuplicateSchemeCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteSchemeCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Click="SaveSchemesButton_Click"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="导入"
                            Command="{Binding ImportSchemeCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="导出"
                            Command="{Binding ExportSchemeCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <ListBox x:Name="SchemesListBox"
                         Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding SchemesView}"
                         SelectedItem="{Binding SelectedScheme, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBox FontSize="15"
                                             FontWeight="SemiBold"
                                             Style="{StaticResource SchemeNameTextBoxStyle}"
                                             Text="{Binding SchemeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding LastModifiedText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.78*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.35*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
          Background="{DynamicResource TabItemBackgroundBrush}"
          BorderBrush="{DynamicResource TabItemBorderBrush}"
          BorderThickness="1"
          CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="方案工步" />
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Right"
                          HorizontalAlignment="Right"
                          Orientation="Horizontal">
                                    <Button Content="添加工步"
                          Command="{Binding AddWorkStepToSchemeCommand}"
                          Style="{StaticResource PrimaryActionButtonStyle}" />
                                    <Button Margin="12,0,0,0"
                          Content="删除"
                          Command="{Binding RemoveWorkStepFromSchemeCommand}"
                          Style="{StaticResource ActionButtonStyle}" />
                                    <Button Margin="12,0,0,0"
                          Content="撤销"
                          Command="{Binding UndoRemoveSchemeStepCommand}"
                          Style="{StaticResource ActionButtonStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Grid.Row="1"
                     Margin="0,8,0,10"
                     Foreground="{DynamicResource AppMutedTextBrush}"
                     Text="直接在方案中维护工步，拖拽可调整顺序。"
                     TextWrapping="Wrap" />

                            <Grid Grid.Row="2">
                                <DataGrid x:Name="SchemeStepsDataGrid"
                        HorizontalScrollBarVisibility="Disabled"
                        ItemsSource="{Binding SelectedScheme.Steps}"
                        SelectedItem="{Binding SelectedSchemeStep, Mode=TwoWay}"
                        IsReadOnly="False"
                        AllowDrop="True"
                        PreviewMouseLeftButtonDown="SchemeStepsDataGrid_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="SchemeStepsDataGrid_PreviewMouseMove"
                        PreviewMouseRightButtonDown="SchemeStepsDataGrid_PreviewMouseRightButtonDown"
                        DragOver="SchemeStepsDataGrid_DragOver"
                        DragLeave="SchemeStepsDataGrid_DragLeave"
                        Drop="SchemeStepsDataGrid_Drop"
                        Style="{StaticResource ColumnsDataGridStyle}">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                   Style="{StaticResource StructureContextMenuStyle}">
                                            <MenuItem Header="添加工步"
                                    Command="{Binding AddWorkStepToSchemeCommand}"
                                    Style="{StaticResource StructureContextMenuItemStyle}">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="32" Height="32">
                                                        <Canvas Width="16" Height="16">
                                                            <Path Style="{StaticResource ContextMenuIconPathStyle}"
                                                Data="M4,8 L12,8 M8,4 L8,12" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="删除工步"
                                    Command="{Binding RemoveWorkStepFromSchemeCommand}"
                                    Style="{StaticResource StructureContextMenuItemStyle}">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="32" Height="32">
                                                        <Canvas Width="16" Height="16">
                                                            <Path Style="{StaticResource ContextMenuIconPathStyle}"
                                                Data="M5,5 L11,5 M7,5 L7,4 L9,4 L9,5 M6,7 L6.4,13 L9.6,13 L10,7 M7.5,8 L7.5,12 M8.5,8 L8.5,12" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="76">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Content="启用"
                                            IsChecked="{Binding DataContext.AreAllSchemeStepsStartupEnabled, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsStartupEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Width="72"
                                          Header="序号"
                                          Binding="{Binding DisplayOrder}"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          EditingElementStyle="{StaticResource CellTextBoxStyle}" />
                                        <DataGridTextColumn Width="1.45*"
                                          Header="工步名称"
                                          Binding="{Binding SchemeStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          EditingElementStyle="{StaticResource CellTextBoxStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Canvas x:Name="SchemeStepDropIndicatorCanvas"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      IsHitTestVisible="False">
                                    <Border x:Name="SchemeStepDropIndicator"
                          Height="3"
                          CornerRadius="2"
                          Visibility="Collapsed"
                          Background="{DynamicResource PrimaryButtonBrush}" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
          Padding="16"
          Background="{DynamicResource TabItemBackgroundBrush}"
          BorderBrush="{DynamicResource TabItemBorderBrush}"
          BorderThickness="1"
          CornerRadius="12">
                        <Grid DataContext="{Binding SchemeStepEditor}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="步骤编辑" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="新建步骤"
                          Command="{Binding AddOperationCommand}"
                          Style="{StaticResource PrimaryActionButtonStyle}" />
                                    <Button Margin="12,0,0,0"
                          Content="复制步骤"
                          Command="{Binding CopyOperationCommand}"
                          Style="{StaticResource ActionButtonStyle}" />
                                    <Button Margin="12,0,0,0"
                          Content="粘贴步骤"
                          Command="{Binding PasteOperationCommand}"
                          Style="{StaticResource ActionButtonStyle}" />
                                    <Button Margin="12,0,0,0"
                          Content="删除步骤"
                          Command="{Binding DeleteOperationCommand}"
                          Style="{StaticResource ActionButtonStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <StackPanel Grid.Row="1" Margin="0,8,0,10">
                                <TextBlock FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AppContentTextBrush}"
                         Text="{Binding DataContext.SelectedSchemeStep.SchemeStepName, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, TargetNullValue=未选择方案工步}" />
                                <TextBlock Margin="0,6,0,0"
                         Foreground="{DynamicResource AppMutedTextBrush}"
                         Text="双击步骤进入编辑抽屉，拖拽可调整步骤顺序。"
                         TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <DataGrid x:Name="OperationsDataGrid" HorizontalScrollBarVisibility="Disabled"
                        ItemsSource="{Binding SelectedWorkStep.Steps}"
                        SelectedItem="{Binding SelectedOperation, Mode=TwoWay}"
                        AllowDrop="True"
                        PreviewMouseLeftButtonDown="OperationsDataGrid_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="OperationsDataGrid_PreviewMouseMove"
                        DragOver="OperationsDataGrid_DragOver"
                        DragLeave="OperationsDataGrid_DragLeave"
                        Drop="OperationsDataGrid_Drop"
                        MouseDoubleClick="OperationsDataGrid_MouseDoubleClick"
                        Style="{StaticResource ColumnsDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="56" Header="选择">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding DataContext.AreAllOperationsChecked, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Width="64"
                                          Header="序号"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          Binding="{Binding DisplayOrder}" />
                                        <DataGridTextColumn Width="*"
                                          Header="操作对象"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          Binding="{Binding OperationObject}" />
                                        <DataGridTextColumn Width="*"
                                          Header="调用方法"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          Binding="{Binding InvokeMethod}" />
                                        <DataGridTextColumn Width="*"
                                          Header="返回值"
                                          IsReadOnly="True"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          Binding="{Binding ReturnValue}" />
                                        <DataGridTextColumn Width="96"
                                          Header="延时(ms)"
                                          ElementStyle="{StaticResource CellTextBlockStyle}"
                                          EditingElementStyle="{StaticResource CellTextBoxStyle}"
                                          Binding="{Binding DelayMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Canvas x:Name="OperationDropIndicatorCanvas"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      IsHitTestVisible="False">
                                    <Border x:Name="OperationDropIndicator"
                          Height="3"
                          CornerRadius="2"
                          Visibility="Collapsed"
                          Background="{DynamicResource PrimaryButtonBrush}" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid x:Name="OperationDrawerHost"
                  Grid.ColumnSpan="3"
                  Panel.ZIndex="30"
                  Opacity="0"
                  IsHitTestVisible="False"
                  DataContext="{Binding SchemeStepEditor}">
                <Border Background="#3A000000"
      MouseLeftButtonDown="OperationDrawerBackdrop_MouseLeftButtonDown" />

                <Border Margin="24,120,24,24"
                        MaxWidth="1320"
                        MinHeight="420"
                        MaxHeight="680"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DrawerBorderStyle}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="OperationDrawerTranslateTransform" Y="56" />
                    </Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                         Text="{Binding OperationDrawerTitle}" />
                                <TextBlock Margin="0,8,0,0"
                         Foreground="{DynamicResource AppMutedTextBrush}"
                         Text="{Binding SelectedWorkStep.StepName}" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right"
                      HorizontalAlignment="Right"
                      Orientation="Horizontal">
                                <Button Content="取消"
                      Command="{Binding CloseOperationDrawerCommand}"
                      Style="{StaticResource ActionButtonStyle}" />
                                <Button Content="保存"
                      Command="{Binding SaveOperationDrawerCommand}"
                      Style="{StaticResource PrimaryActionButtonStyle}" />
                            </StackPanel>
                        </DockPanel>

                        <businessViews:OperationEditorView Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
