<UserControl x:Class="Module.Business.Views.StationConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:businessViews="clr-namespace:Module.Business.Views.Controls.Views"
             xmlns:flowchartViews="clr-namespace:ControlLibrary.ControlViews.Flowchart;assembly=ControlLibrary"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1600">
    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="工位配置" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding StationCountText}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="管理多个工位，并在右侧维护工位自身的流程图。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <searchBox:SearchBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     PlaceholderText="搜索工位..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,16">
                    <Button Content="新建"
                            Command="{Binding NewStationCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
                            Command="{Binding DuplicateStationCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteStationCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveStationCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <ListBox Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding StationsView}"
                         SelectedItem="{Binding SelectedStation, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppContentTextBrush}"
                                               Text="{Binding StationName}" />
                                    <Border DockPanel.Dock="Right"
                                            Margin="10,0,0,0"
                                            MinWidth="78"
                                            Padding="8,2"
                                            Background="{DynamicResource PrimaryButtonBrush}"
                                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                                   Text="{Binding StationCode}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding Summary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="当前工位" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="12,6"
                                VerticalAlignment="Top"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{Binding PageStatusBrush}"
                                       Text="{Binding PageStatusText}" />
                        </Border>
                    </DockPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel IsEnabled="{Binding HasSelectedStation}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                                               Text="工位名称" />
                                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                                             Text="{Binding SelectedStation.StationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                                               Text="工位编码" />
                                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                                             Text="{Binding SelectedStation.StationCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <CheckBox Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,10"
          Content="是否启用"
          IsChecked="{Binding SelectedStation.IsEnabled, Mode=TwoWay}" />
                            </Grid>

                            
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <flowchartViews:FlowchartNodePanelView x:Name="FlowchartPanel"
                                                       Document="{Binding SelectedStation.FlowchartDocument, Mode=TwoWay}"
                                                       NodeDoubleClick="Editor_NodeDoubleClick" />
            </Border>
        </Grid>

        <Grid x:Name="NodeOperationEditorHost"
              Grid.ColumnSpan="3"
              Panel.ZIndex="60"
              Visibility="Collapsed">
            <Border Background="#59000000"
                    MouseLeftButtonDown="NodeOperationEditorBackdrop_MouseLeftButtonDown" />

            <Border Width="980"
                    MaxWidth="1180"
                    MaxHeight="760"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardBorderStyle}">
                <Grid DataContext="{Binding ElementName=NodeOperationEditorHost, Path=Tag}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="编辑步骤" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding SelectedWorkStep.StepName}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding PageStatusBrush}"
                                   Text="{Binding PageStatusText}" />
                    </DockPanel>

                    <businessViews:StationOperationEditorView Grid.Row="1" />

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="取消"
                                Click="NodeOperationEditorCancelButton_Click"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="保存"
                                Click="NodeOperationEditorSaveButton_Click"
                                Style="{StaticResource PrimaryActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
