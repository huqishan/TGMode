<UserControl x:Class="Module.Business.Views.FlowchartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:ControlLibrary.Controls.FlowchartEditor.Control;assembly=ControlLibrary"
             xmlns:vm="clr-namespace:Module.Business.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600"
             d:DesignWidth="1100">
    <UserControl.DataContext>
        <vm:FlowchartViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="PaletteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="14"
                Background="{DynamicResource TabItemBackgroundBrush}"
                BorderBrush="{DynamicResource TabItemBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="流程图组件" />
                <TextBlock Margin="0,8,0,18"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="按住左键拖动按钮到右侧画布，创建新的流程节点。" 
                           TextWrapping="Wrap" />

                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <Button x:Name="NewButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="新建"
                            Command="{Binding NewFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}" />
                    <Button x:Name="SaveButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="保存"
                            Command="{Binding SaveFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}" />
                    <Button x:Name="OpenButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="打开"
                            Command="{Binding OpenFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}" />
                    <Button x:Name="ExecuteButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="执行"
                            Command="{Binding ExecuteFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}" />
                    <Button x:Name="PauseButton"
                            Command="{Binding PauseFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Setter Property="Content" Value="暂停" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Content" Value="继续" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="StopButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="结束"
                            Command="{Binding StopFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}" />
                </UniformGrid>

                <TextBlock x:Name="ExecutionStatusText"
                           Margin="0,0,0,18"
                           Foreground="{Binding ExecutionStatusBrush}"
                           Text="{Binding ExecutionStatusText}"
                           TextWrapping="Wrap" />

                <ItemsControl ItemsSource="{Binding NodeTemplates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FlowchartNodeTemplate}">
                            <Button Style="{StaticResource PaletteButtonStyle}"
                                    Content="{Binding DisplayName}"
                                    Tag="{Binding}"
                                    PreviewMouseLeftButtonDown="PaletteItem_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="PaletteItem_PreviewMouseLeftButtonUp"
                                    PreviewMouseMove="PaletteItem_PreviewMouseMove" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,12,0,12" />

                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="操作说明" FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="1. 左键拖按钮到画布创建节点"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="2. 拖节点四边连接点创建箭头线"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="3. 左键拖空白区域平移，滚轮缩放，Delete 删除选中项"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <controls:FlowchartEditorControl x:Name="Editor" Grid.Column="2" />
    </Grid>
</UserControl>
