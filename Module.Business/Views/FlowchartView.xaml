<UserControl x:Class="Module.Business.Views.FlowchartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:businessViews="clr-namespace:Module.Business.Views.Controls.Views"
             xmlns:controls="clr-namespace:ControlLibrary.Controls.FlowchartEditor.Control;assembly=ControlLibrary"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             xmlns:vm="clr-namespace:Module.Business.ViewModels"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1600">
    <UserControl.DataContext>
        <vm:FlowchartViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="FlowchartPaletteButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="流程图配置" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding FlowchartCountText}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="管理多个流程图，并在右侧编辑节点与连线。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <searchBox:SearchBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     PlaceholderText="搜索流程图..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="2" Columns="4" Margin="0,16,0,16">
                    <Button Content="新建"
                            Command="{Binding NewFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
                            Command="{Binding DuplicateFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteFlowchartCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveFlowchartCommand}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <ListBox Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding FlowchartsView}"
                         SelectedItem="{Binding SelectedFlowchart, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppContentTextBrush}"
                                               Text="{Binding Name}" />
                                    <Border DockPanel.Dock="Right"
                                            Margin="10,0,0,0"
                                            MinWidth="70"
                                            Padding="8,2"
                                            Background="{DynamicResource PrimaryButtonBrush}"
                                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                                   Text="{Binding NodeCountText}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding Summary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MinHeight="136"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="当前流程图" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="12,6"
                                VerticalAlignment="Top"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{Binding PageStatusBrush}"
                                       Text="{Binding PageStatusText}" />
                        </Border>
                    </DockPanel>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.8*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="流程图名称" />
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding SelectedFlowchart.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <DockPanel LastChildFill="False">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding ExecutionStatusBrush}"
                                           Text="{Binding ExecutionStatusText}"
                                           TextWrapping="Wrap" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="导入"
                                            Command="{Binding OpenFlowchartCommand}"
                                            CommandParameter="{Binding ElementName=Editor}"
                                            Style="{StaticResource ActionButtonStyle}" />
                                    <Button Content="导出"
                                            Command="{Binding ExportFlowchartCommand}"
                                            CommandParameter="{Binding ElementName=Editor}"
                                            Style="{StaticResource ActionButtonStyle}" />
                                    <Button Content="运行"
                                            Command="{Binding ExecuteFlowchartCommand}"
                                            CommandParameter="{Binding ElementName=Editor}"
                                            Style="{StaticResource PrimaryActionButtonStyle}" />
                                    <Button Command="{Binding PauseFlowchartCommand}"
                                            CommandParameter="{Binding ElementName=Editor}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
                                                <Setter Property="Content" Value="暂停" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                        <Setter Property="Content" Value="继续" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="停止"
                                            Command="{Binding StopFlowchartCommand}"
                                            CommandParameter="{Binding ElementName=Editor}"
                                            Style="{StaticResource ActionButtonStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding CurrentFlowchartSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="节点面板" />
                            <TextBlock Margin="0,8,0,14"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="拖动组件到画布以创建节点。"
                                       TextWrapping="Wrap" />

                            <ItemsControl ItemsSource="{Binding NodeTemplates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FlowchartNodeTemplate}">
                                        <Button Style="{StaticResource FlowchartPaletteButtonStyle}"
                                                Tag="{Binding}"
                                                PreviewMouseLeftButtonDown="PaletteItem_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="PaletteItem_PreviewMouseLeftButtonUp"
                                                PreviewMouseMove="PaletteItem_PreviewMouseMove">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left"
                                                        Width="4"
                                                        Height="22"
                                                        Margin="0,0,10,0"
                                                        Background="{Binding AccentBrush}"
                                                        CornerRadius="2" />
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppContentTextBrush}"
                                                           Text="{Binding DisplayName}" />
                                            </DockPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Margin="0,10,0,12" />

                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="操作说明" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="拖动节点边缘的锚点以创建连线。"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="拖动画布空白区域可平移，滚动鼠标滚轮可缩放，按删除键可删除选中项。"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="双击处理块或判断块可打开同一个编辑步骤弹框。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <controls:FlowchartEditorControl x:Name="Editor"
                                                     Grid.Column="2"
                                                     Document="{Binding SelectedFlowchart.Document, Mode=TwoWay}"
                                                     NodeDoubleClick="Editor_NodeDoubleClick" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="NodeOperationEditorHost"
              Grid.ColumnSpan="3"
              Panel.ZIndex="60"
              Visibility="Collapsed">
            <Border Background="#59000000"
                    MouseLeftButtonDown="NodeOperationEditorBackdrop_MouseLeftButtonDown" />

            <Border Width="980"
                    MaxWidth="1180"
                    MaxHeight="760"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardBorderStyle}">
                <Grid DataContext="{Binding ElementName=NodeOperationEditorHost, Path=Tag}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="编辑步骤" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding SelectedWorkStep.StepName}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding PageStatusBrush}"
                                   Text="{Binding PageStatusText}" />
                    </DockPanel>

                    <businessViews:OperationEditorView Grid.Row="1" />

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Content="取消"
                                Click="NodeOperationEditorCancelButton_Click"
                                Style="{StaticResource ActionButtonStyle}" />
                        <Button Content="保存"
                                Click="NodeOperationEditorSaveButton_Click"
                                Style="{StaticResource PrimaryActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

