<UserControl x:Class="Module.Business.Views.Controls.Views.OperationEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converts="clr-namespace:ControlLibrary.Converts;assembly=ControlLibrary"
             xmlns:luaEditor="clr-namespace:ControlLibrary.Controls.LuaScripEditor.Control;assembly=ControlLibrary"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="760">
    <UserControl.Resources>
        <converts:ComparisonToVisibilityConvert x:Key="comp2Vis" />
        <converts:InvertVisibilityConvert x:Key="invertVis" />
        <BooleanToVisibilityConverter x:Key="b2V" />
    </UserControl.Resources>

    <ScrollViewer Margin="0,18,0,18"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               Text="&#x63CF;&#x8FF0;" />
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding EditingRemark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Width="100"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Right">
                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               Text="&#x5EF6;&#x65F6;(ms)" />
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding EditingDelayMillisecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel>
                <TextBlock Style="{StaticResource FieldLabelStyle}"
                           Text="&#x64CD;&#x4F5C;&#x5BF9;&#x8C61;" />
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Margin="12,0,0,0"
                            Content="&#x5237;&#x65B0;"
                            Command="{Binding RefreshOperationObjectsCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <ComboBox x:Name="operationObj"
                              Style="{StaticResource InputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              ItemsSource="{Binding OperationObjectOptions}"
                              SelectedItem="{Binding EditingOperationObject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </StackPanel>

            <Grid>
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProtocolCommandSelectionVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               Text="&#x534F;&#x8BAE;" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              ItemsSource="{Binding ProtocolOptions}"
                              SelectedItem="{Binding EditingProtocolName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               Text="&#x6307;&#x4EE4;" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                              ItemsSource="{Binding CommandOptions}"
                              SelectedItem="{Binding EditingCommandName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel Visibility="{Binding IsSystemOrJudgeOperationSelected, Converter={StaticResource b2V}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x8C03;&#x7528;&#x65B9;&#x6CD5;" />
                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                  ItemsSource="{Binding InvokeMethodOptions}"
                                  SelectedItem="{Binding EditingInvokeMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x65B9;&#x6CD5;&#x5907;&#x6CE8;" />
                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                  ItemsSource="{Binding InvokeMethodRemarkOptions}"
                                  SelectedItem="{Binding EditingInvokeMethodRemark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Grid x:Name="luaEditorGrid"
                  Height="490"
                  Margin="0,14,0,0"
                  Visibility="{Binding ElementName=operationObj, Path=SelectedItem, Converter={StaticResource comp2Vis}, ConverterParameter='Lua'}">
                <luaEditor:LuaScriptEditor ScriptText="{Binding EditingLuaScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <DockPanel Margin="0,14,0,8"
                       LastChildFill="False"
                       Visibility="{Binding ElementName=luaEditorGrid, Path=Visibility, Converter={StaticResource invertVis}}">
                <TextBlock DockPanel.Dock="Left"
                           Style="{StaticResource FieldLabelStyle}"
                           Text="&#x8C03;&#x7528;&#x65B9;&#x6CD5;&#x53C2;&#x6570;" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#x6DFB;&#x52A0;&#x53C2;&#x6570;"
                            Command="{Binding AddInvokeParameterCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="&#x5220;&#x9664;&#x53C2;&#x6570;"
                            Command="{Binding DeleteInvokeParameterCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Height="300"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding ElementName=luaEditorGrid, Path=Visibility, Converter={StaticResource invertVis}}"
                      ItemsSource="{Binding EditingInvokeParameters}"
                      SelectedItem="{Binding SelectedEditingInvokeParameter, Mode=TwoWay}"
                      Style="{StaticResource ColumnsDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="72"
                                        Header="&#x5E8F;&#x53F7;"
                                        ElementStyle="{StaticResource CellTextBlockStyle}"
                                        EditingElementStyle="{StaticResource CellTextBoxStyle}"
                                        Binding="{Binding Sequence, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    <DataGridTemplateColumn Width="1.1*" Header="&#x53C2;&#x6570;&#x7C7B;&#x578B;">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CellTextBlockStyle}"
                                           Text="{Binding Type}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                          ItemsSource="{Binding DataContext.ParameterTypeOptions, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                          SelectedItem="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="1.3*" Header="&#x53C2;&#x6570;&#x503C;">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource CellTextBlockStyle}"
                                           Text="{Binding Value}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBox x:Name="ParameterValueTextBox"
                                             Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox x:Name="ParameterValueComboBox"
                                              Style="{StaticResource EditableInputComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                              ItemsSource="{Binding ValueOptions}"
                                              Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Visibility="Collapsed" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding UsesComboValueEditor}" Value="True">
                                        <Setter TargetName="ParameterValueTextBox" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="ParameterValueComboBox" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="1.4*"
                                        Header="&#x63CF;&#x8FF0;"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CellTextBlockStyle}"
                                        EditingElementStyle="{StaticResource CellTextBoxStyle}"
                                        Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Visibility="{Binding ElementName=luaEditorGrid, Path=Visibility, Converter={StaticResource invertVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x8FD4;&#x56DE;&#x503C;" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding EditingReturnValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <CheckBox x:Name="showView"
                              Grid.Column="1"
                              Margin="16,35,0,0"
                              VerticalAlignment="Center"
                              Content="&#x663E;&#x793A;&#x5230;&#x754C;&#x9762;"
                              IsChecked="{Binding EditingShowDataToView, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="0,12,0,0"
                      Visibility="{Binding ElementName=showView, Path=IsChecked, Converter={StaticResource b2V}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x6570;&#x636E;&#x540D;&#x79F0;" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding EditingViewDataName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x5224;&#x65AD;&#x7C7B;&#x578B;" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding EditingViewJudgeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#x5224;&#x65AD;&#x6761;&#x4EF6;" />
                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding EditingViewJudgeCondition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
