<UserControl x:Class="Module.Business.Views.WorkStepConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:searchBox="clr-namespace:ControlLibrary.Controls.SearchBox.Control;assembly=ControlLibrary"
             xmlns:vm="clr-namespace:Module.Business.ViewModels"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1800">
    <UserControl.DataContext>
        <vm:WorkStepConfigurationViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="BusinessDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource TabItemSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="BusinessDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource NavSelectedItemBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BusinessDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BusinessInputTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppContentTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BusinessComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppContentTextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="工步配置" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding WorkStepCountText}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="按产品名称维护工步分类，每个工步包含操作对象和调用方法组成的步骤列表。"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="产品名称" />
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Margin="12,0,0,0"
                                Content="刷新"
                                Command="{Binding RefreshProductsCommand}"
                                Style="{StaticResource ActionButtonStyle}" />
                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                  Height="{Binding ActualHeight, ElementName=WorkStepSearchBox}"
                                  ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                  ItemsSource="{Binding ProductOptions}"
                                  SelectedItem="{Binding SelectedProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </StackPanel>

                <searchBox:SearchBox x:Name="WorkStepSearchBox"
                                     Grid.Row="2"
                                     Margin="0,12,0,0"
                                     PlaceholderText="搜索工步配置..."
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <UniformGrid Grid.Row="3" Columns="4" Margin="0,16,0,16">
                    <Button Content="新建"
                            Command="{Binding NewWorkStepCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    <Button Content="复制"
                            Command="{Binding DuplicateWorkStepCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除"
                            Command="{Binding DeleteWorkStepCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveWorkStepsCommand}"
                            Style="{StaticResource ActionButtonStyle}" />
                </UniformGrid>

                <ListBox Grid.Row="4"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         ItemsSource="{Binding WorkStepsView}"
                         SelectedItem="{Binding SelectedWorkStep, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppContentTextBrush}"
                                               Text="{Binding StepName}" />
                                    <Border DockPanel.Dock="Right"
                                            Margin="10,0,0,0"
                                            Padding="8,2"
                                            Background="{DynamicResource PrimaryButtonBrush}"
                                            BorderBrush="{DynamicResource TabItemBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                                                   Text="{Binding OperationCount}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding ProductName}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MinHeight="130"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前工步" />
                        <Border DockPanel.Dock="Right"
                                Margin="16,0,0,0"
                                Padding="12,6"
                                VerticalAlignment="Top"
                                Background="{DynamicResource TabCardBackgroundBrush}"
                                BorderBrush="{DynamicResource TabItemBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{Binding PageStatusBrush}"
                                       Text="{Binding PageStatusText}" />
                        </Border>
                    </DockPanel>

                    <Grid Margin="0,14,0,0">
                        <StackPanel>
                            <!--
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="产品名称" />
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="工步名称" />
                            -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="工步名称" />
                            <TextBox Style="{StaticResource BusinessInputTextBoxStyle}"
                                     Text="{Binding SelectedWorkStep.StepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="步骤列表" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Border Margin="0,0,12,0"
                                    Padding="10,5"
                                    Background="{DynamicResource TabCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource TabItemBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock FontWeight="SemiBold" Text="{Binding OperationCountText}" VerticalAlignment="Center"/>
                            </Border>
                            <Button Content="新建步骤"
                                    Command="{Binding AddOperationCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}" />
                            <Button Content="删除步骤"
                                    Command="{Binding DeleteOperationCommand}"
                                    Style="{StaticResource ActionButtonStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,10"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="选择工步后，在这里维护该工步的操作对象与调用方法。"
                               TextWrapping="Wrap" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SelectedWorkStep.Steps}"
                              SelectedItem="{Binding SelectedOperation, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              AlternationCount="2"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource TabCardBackgroundBrush}"
                              Foreground="{DynamicResource AppContentTextBrush}"
                              RowBackground="{DynamicResource TabCardBackgroundBrush}"
                              AlternatingRowBackground="{DynamicResource TabItemBackgroundBrush}"
                              ColumnHeaderStyle="{StaticResource BusinessDataGridHeaderStyle}"
                              RowStyle="{StaticResource BusinessDataGridRowStyle}"
                              CellStyle="{StaticResource BusinessDataGridCellStyle}"
                              RowHeight="42">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                Header="操作对象"
                                                Binding="{Binding OperationObject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Width="*"
                                                Header="调用方法"
                                                Binding="{Binding InvokeMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
